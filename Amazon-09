const renderConflictAnalysis = () => {
  const tbody = $("conflictTable")?.querySelector("tbody"); 
  if (!tbody) return; 
  if (!AdsStore.view.length) { tbody.innerHTML = ""; return; }
  
  const map = new Map();
  for (const r of AdsStore.view) {
    if (!r.searchTerm || isASINLike(r.searchTerm)) continue; 
    
    let matchGroup = "Auto";
    if (r.matchType.toLowerCase().includes("exact")) matchGroup = "Exact";
    else if (r.matchType.toLowerCase().includes("broad") || r.matchType.toLowerCase().includes("phrase")) matchGroup = "Broad/Phrase";

    const loc = `${r.campaign} > ${r.adGroup} [${matchGroup}]`;
    const conflictKey = `${r.searchTerm}::${matchGroup}`; 

    if (!map.has(conflictKey)) { map.set(conflictKey, { term: r.searchTerm, locMap: new Map(), spend: 0, orders: 0, sales: 0 }); }
    const entry = map.get(conflictKey);
    entry.locMap.set(loc, SafeMath.add(entry.locMap.get(loc) || 0, r.spend));
    entry.spend = SafeMath.add(entry.spend, r.spend); 
    entry.orders += r.orders; 
    entry.sales = SafeMath.add(entry.sales, r.sales);
  }
  
  const conflicts = [];
  for (const [key, data] of map.entries()) {
    const activeLocs = Array.from(data.locMap.entries()).filter(([l, sp]) => sp > 2.0).map(x => x[0]);
    if (activeLocs.length > 1 && data.spend > 5) {
      conflicts.push({ term: data.term, count: activeLocs.length, locs: activeLocs, spend: data.spend, orders: data.orders, roas: data.spend > 0 ? data.sales / data.spend : 0 });
    }
  }
  conflicts.sort((a,b) => b.spend - a.spend);
  
  if (conflicts.length === 0) { 
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--muted)">未检测到明显的内部竞争（条件：同等匹配类型下，在 2 个不同组分别消耗 > $2）</td></tr>`; 
    return; 
  }
  
  tbody.innerHTML = conflicts.slice(0, 50).map(c => {
    const displayLocs = c.locs.slice(0, 2).map(l => `<div style="font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escapeHtml(l)}</div>`).join(""); 
    const moreCount = c.locs.length > 2 ? `<div style="font-size:10px;color:var(--muted)">+${c.locs.length - 2} more...</div>` : ""; 
    const fullLocs = c.locs.join("\n");
    return `<tr data-term="${escapeHtml(c.term)}" style="cursor:pointer" title="点击筛选该词"><td style="font-weight:600;color:var(--text)">${escapeHtml(c.term)}</td><td><span class="tag bad" style="font-size:11px">${c.count}个</span></td><td title="${escapeHtml(fullLocs)}">${displayLocs}${moreCount}</td><td>${fmtMoney(c.spend)}</td><td>${fmtInt(c.orders)}</td><td>${c.roas.toFixed(2)}</td></tr>`;
  }).join("");
};

