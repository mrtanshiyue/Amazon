const renderIsolationAnalysis = () => {
  const tbody = $("isolationTable")?.querySelector("tbody"); 
  if (!tbody) return; 
  if (!AdsStore.view.length) { tbody.innerHTML = ""; return; }

  const minOrders = Math.max(1, Math.floor(safeNum($("isoMinOrders")?.value || 3)));

  const nonExactMap = new Map();
  for (let i = 0; i < AdsStore.view.length; i++) {
    const r = AdsStore.view[i];
    if (!r.searchTerm || isASINLike(r.searchTerm)) continue; 
    
    const matchLower = (r.matchType || "").toLowerCase();
    const isExact = matchLower.includes("exact");
    
    if (!isExact) {
      if (!nonExactMap.has(r.searchTerm)) {
        nonExactMap.set(r.searchTerm, { term: r.searchTerm, sources: new Set(), sourceLocs: [], rows: [] });
      }
      const entry = nonExactMap.get(r.searchTerm);
      entry.sources.add(matchLower || "auto");
      entry.sourceLocs.push({ camp: r.campaign, adg: r.adGroup, match: matchLower });
      entry.rows.push(r);
    }
  }

  const candidates = [];
  for (const [term, data] of nonExactMap.entries()) {
    const m = sumMetrics(data.rows);
    if (m.orders >= minOrders) {
      const cleanTerm = cleanTargetForExact(term);
      const exactStats = AdsStore.indexes.exactTerm.get(cleanTerm);
      const isIsolated = !!exactStats;
      
      if (!isIsolated) {
        candidates.push({ term: term, sourceLocs: data.sourceLocs, source: Array.from(data.sources).join(", "), isIsolated: false, statusHtml: `<span class="tag bad">未提取 (Un-isolated)</span>`, actionHtml: `<span style="font-size:11px;font-weight:600;color:var(--accent);">提取 Exact + 来源组精准否定</span>`, ...m });
      } else if (exactStats.impr < 50 && m.orders > 0) {
        candidates.push({ term: term, sourceLocs: data.sourceLocs, source: Array.from(data.sources).join(", "), isIsolated: true, statusHtml: `<span class="tag warn">⚠️ 假隔离(曝光不足)</span>`, actionHtml: `<span style="font-size:11px;font-weight:600;color:var(--warn);">去精确组提价，争夺曝光！</span>`, ...m });
      }
    }
  }

  candidates.sort((a, b) => b.sales - a.sales);
  AdsStore.isolationRows = candidates;

  if (candidates.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--muted)">🎉 太棒了！所有符合条件的高转化词均已完成精准隔离，且没有发现假隔离。</td></tr>`;
    return;
  }

  tbody.innerHTML = candidates.slice(0, 50).map(c => {
    return `<tr>
      <td style="font-weight:600;color:var(--text)">${escapeHtml(c.term)}</td>
      <td style="color:var(--muted);text-transform:capitalize;">${escapeHtml(c.source)}</td>
      <td>${c.statusHtml}</td>
      <td>${fmtMoney(c.spend)}</td>
      <td>${fmtInt(c.orders)}</td>
      <td><span style="color:var(--good);font-weight:600">${c.roas.toFixed(2)}</span></td>
      <td>${c.actionHtml}</td>
    </tr>`;
  }).join("");
};

