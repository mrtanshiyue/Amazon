const pickCol = (header, aliases) => { 
  const normHeader = header.map(cleanHeader); 
  for (const a of aliases) { 
    const target = cleanHeader(a); 
    const idx = normHeader.indexOf(target); 
    if (idx >= 0) return header[idx]; 
  } 
  return null; 
};

const buildMap = (rows) => { 
  const header = rows.length ? Object.keys(rows[0]) : []; 
  const map = {}; 
  for (const key in COL_MAP_ALIASES) map[key] = pickCol(header, COL_MAP_ALIASES[key]); 
  if (!map.date) throw new Error("Ads Report: 未找到日期列 (Date)."); 
  map.adProductType = detectAdProduct(header);
  return map; 
};

const buildBrMap = (rows) => { 
  const header = rows.length ? Object.keys(rows[0]) : []; 
  const map = {}; 
  for (const key in BR_MAP_ALIASES) map[key] = pickCol(header, BR_MAP_ALIASES[key]); 
  return map; 
};

const buildPlacementMap = (rows) => { 
  const header = rows.length ? Object.keys(rows[0]) : []; 
  const map = {}; 
  for (const key in PLACEMENT_MAP_ALIASES) map[key] = pickCol(header, PLACEMENT_MAP_ALIASES[key]); 
  return map; 
};

const normalizeRow = (raw, map, sourceFile) => {
  if (!raw) return null; 
  const impr = safeNum(raw[map.impr]);
  const clicks = safeNum(raw[map.clicks]);
  const spend = safeNum(raw[map.spend]); 
  const sales = safeNum(raw[map.sales7d]);
  const orders = safeNum(raw[map.orders7d]); 
  const st = String(raw[map.searchTerm] ?? "").trim();
  const acosVal = sales > 0 ? spend / sales : (spend > 0 ? Infinity : 0);

  return {
    sourceFile: intern(sourceFile), 
    adProduct: intern(map.adProductType || "SP"), // 新增：广告类型
    date: intern(toISODate(raw[map.date])), 
    portfolio: intern(String(raw[map.portfolio] ?? "").trim()), 
    campaign: intern(String(raw[map.campaign] ?? "").trim()), 
    adGroup: intern(String(raw[map.adGroup] ?? "").trim()), 
    targeting: intern(String(raw[map.targeting] ?? "").trim()), 
    matchType: intern(String(raw[map.matchType] ?? "").trim()), 
    searchTerm: st, 
    searchTermLower: st.toLowerCase(), 
    searchTermRoot: searchTermToRoot(st), 
    impr, clicks, spend, sales: Math.max(0, sales), orders,
    ctr: map.ctr ? safeNum(raw[map.ctr]) : (impr > 0 ? clicks / impr : 0), 
    cpc: map.cpc ? safeNum(raw[map.cpc]) : (clicks > 0 ? spend / clicks : 0), 
    cvr: map.cvr ? safeNum(raw[map.cvr]) : (clicks > 0 ? Math.min(1, orders / clicks) : 0), 
    acos: map.acos ? safeNum(raw[map.acos]) : acosVal, 
    roas: map.roas ? safeNum(raw[map.roas]) : (spend > 0 ? Math.max(0, sales) / spend : 0),
  };
};

const normalizeBrRow = (raw, map, sourceFile) => { 
  const sessions = safeNum(raw[map.sessions]); 
  const units = safeNum(raw[map.units]); 
  const sales = safeNum(raw[map.sales]); 
  const calculatedCvr = sessions > 0 ? Math.min(1, units / sessions) : 0; 
  const calculatedAov = units > 0 ? sales / units : 0; 
  return { 
    sourceFile: intern(sourceFile), 
    asin: intern(String(raw[map.asin] ?? "").trim()), 
    title: String(raw[map.title] ?? "").trim(), 
    sessions, units, sales: Math.max(0, sales), 
    cvr: isFinite(calculatedCvr) ? calculatedCvr : 0, 
    aov: isFinite(calculatedAov) ? calculatedAov : 0 
  }; 
};

const normalizePlacementRow = (raw, map, sourceFile) => {
    if (!raw) return null; 
    const impr = safeNum(raw[map.impr]), clicks = safeNum(raw[map.clicks]), spend = safeNum(raw[map.spend]); 
    const sales = Math.max(0, safeNum(raw[map.sales])), orders = safeNum(raw[map.orders]); 
    let placement = String(raw[map.placement] ?? "").trim();
    
    if (placement.includes("顶部") || placement.toLowerCase().includes("top of search")) placement = "Top of Search (首页首行)"; 
    else if (placement.includes("商品页面") || placement.toLowerCase().includes("product pages")) placement = "Product Pages (商品页面)"; 
    else if (placement.includes("其余位置") || placement.toLowerCase().includes("rest of search")) placement = "Rest of Search (其余位置)";
    
    return { 
      sourceFile: intern(sourceFile), date: intern(toISODate(raw[map.date])), 
      campaign: intern(String(raw[map.campaign] ?? "").trim()), placement: intern(placement), 
      impr, clicks, spend, sales, orders 
    };
};

const isASINLike = (s) => {
  const x = String(s || "").trim(); 
  if (!x || x.length < 10) return false; 
  const candidates = x.match(/[A-Z0-9]{10}/ig); 
  if (!candidates) return false;
  for (const c of candidates) { if (/^[B0-9][A-Z0-9]{9}$/i.test(c) && /\d/.test(c)) return true; }
  return /asin\s*=\s*[A-Z0-9]{10}/i.test(x) || /asin\s*:\s*[A-Z0-9]{10}/i.test(x);
};

const detectRowType = (name, rankBy) => (rankBy === "searchTerm" || rankBy === "searchTermRoot" || rankBy === "targeting") ? (isASINLike(name) ? "asin" : "keyword") : "other";

const checkIsManual = (r) => {
    const lowerMatch = (r.matchType||"").toLowerCase();
    const lowerTargeting = (r.targeting||"").toLowerCase();
    if (["broad", "phrase", "exact", "广泛", "词组", "精准", "精确"].some(m => lowerMatch.includes(m))) return true;
    if (lowerTargeting === "*" || ["close-match", "loose-match", "substitutes", "complements", "宽泛", "紧密", "同类", "补充"].some(m => lowerTargeting.includes(m))) return false;
    if (isASINLike(lowerTargeting) || lowerTargeting.includes("category") || lowerTargeting.includes("asin") || lowerTargeting.includes("分类")) return true;
    return lowerMatch.includes("product") || lowerMatch.includes("targeting") || lowerMatch.includes("商品") || lowerMatch.includes("投放");
};

const cleanTargetForExact = (t) => (t || "").toLowerCase().replace(/[^\w\s]/gi, '').replace(/\s+/g, ' ').trim();

const parseCSV = (file) => new Promise((r,j)=>Papa.parse(file, {header:true, skipEmptyLines: 'greedy', worker: true, complete:res=>r(res.data), error:j}));
const parseXLSX = (file) => new Promise((r,j)=>{ 
  const reader = new FileReader(); 
  reader.onload = (e) => {
    try {
      const wb = XLSX.read(new Uint8Array(e.target.result),{type:"array"});
      r(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:""}));
    } catch(err){ j(err); }
  }; 
  reader.onerror = j; 
  reader.readAsArrayBuffer(file); 
});

const dedupeRows = (rows) => { 
  const seen = new Set(), out = []; 
  for (const r of rows) { 
    const key = `${r.date}|${r.campaign}|${r.adGroup}|${r.targeting}|${r.matchType}|${r.searchTerm}`; 
    if (!seen.has(key)) { seen.add(key); out.push(r); } 
  } 
  return out; 
};

const buildIndexes = () => {
    AdsStore.indexes.exactTerm.clear();
    for (let i = 0; i < AdsStore.all.length; i++) {
        const r = AdsStore.all[i];
        if ((r.matchType || "").toLowerCase().includes("exact")) {
            const cleanTarget = cleanTargetForExact(r.targeting);
            if (cleanTarget) {
                if (!AdsStore.indexes.exactTerm.has(cleanTarget)) AdsStore.indexes.exactTerm.set(cleanTarget, { impr: 0, spend: 0 });
                const existing = AdsStore.indexes.exactTerm.get(cleanTarget);
                existing.impr += r.impr;
                existing.spend += r.spend;
            }
        }
    }
};

const importMultipleFiles = async (files) => {
  clearLog(); 
  if (!libsCheck()) return; 
  const mergeMode = $("mergeMode").value;
  const dedupeMode = $("dedupeMode").value; 
  const maxRows = clamp(safeNum($("maxRows").value) || 500000, 10000, 2000000);
  
  log(`开始导入：${files.length} 个文件（merge=${mergeMode}, dedupe=${dedupeMode}, maxRows=${maxRows}）`); 
  setSubtitle("正在进行多线程数据处理与洗刷...请稍候");
  
  if (mergeMode === "replace") { 
      AdsStore.all = []; AdsStore.biz = []; AdsStore.placement = []; AdsStore.files = []; 
      rootCache.clear(); tokenCache.clear(); clearStringPool(); 
      AdsStore.rankGroups = null; AdsStore.isolationRows = [];
      try { await idbKeyval.clear(); } catch(e) {} 
      log("Replace 模式：已清空历史数据与缓存分片", "warn"); 
  }
  
  for (const file of files) {
    const name = file.name, lower = name.toLowerCase(); log(`读取文件：${name}`);
    try {
      let rows = [];
      if (lower.endsWith(".csv")) { 
        log(`解析 CSV：${name}`); 
        rows = await parseCSV(file); 
      } else if (lower.endsWith(".xlsx") || lower.endsWith(".xls")) { 
        log(`解析 XLSX/XLS：${name}`); 
        rows = await parseXLSX(file); 
      } else { 
        log(`跳过：不支持的文件类型（${name}）`, "warn"); continue; 
      }
      
      rows = rows.filter(r => r && Object.keys(r).length > 0);
      if (!rows.length) { log(`警告：${name} 解析后为空`, "warn"); continue; }
      if (rows.length > maxRows) { 
        log(`警告：${name} 行数 ${rows.length.toLocaleString()} 超过 maxRows，将截断`, "warn"); 
        rows = rows.slice(0, maxRows); 
      }
      
      const header = Object.keys(rows[0]); 
      const normHeader = header.map(cleanHeader);
      
      const hasAsin = normHeader.some(h => ["（子）asin", "(child)asin", "childasin", "子商品asin"].includes(h));
      const hasSessions = normHeader.some(h => ["会话数-总计", "sessions-total", "sessions", "买家访问次数"].includes(h));
      const hasPlacement = normHeader.some(h => ["放置", "placement", "广告位", "位置"].includes(h));
      const hasSearchTerm = normHeader.some(h => ["客户搜索词", "customersearchterm", "searchterm"].includes(h));

      if (hasAsin && hasSessions) {
         log(`>> 检测到业务报告 (Business Report) 格式`, "good"); 
         const brMap = buildBrMap(rows); 
         const mappedRows = await processInChunks(rows, r => normalizeBrRow(r, brMap, name)); 
         const norm = mappedRows.filter(r => r.asin); 
         AdsStore.biz = AdsStore.biz.concat(norm); 
         log(`导入业务报告：${name} → ${norm.length.toLocaleString()} 行`, "good");
      } else if (hasPlacement && !hasSearchTerm) { 
         log(`>> 检测到广告位报告 (Placement Report) 格式`, "good"); 
         const plMap = buildPlacementMap(rows); 
         const mappedRows = await processInChunks(rows, r => normalizePlacementRow(r, plMap, name)); 
         const norm = mappedRows.filter(r => r.placement); 
         AdsStore.placement = AdsStore.placement.concat(norm); 
         log(`导入广告位报告：${name} → ${norm.length.toLocaleString()} 行`, "good");
      } else {
         try { 
           const map = buildMap(rows); 
           log(`标准化字段 + 提取时序特征 (发现类型: ${map.adProductType})：${name}`); 
           const mappedRows = await processInChunks(rows, r => normalizeRow(r, map, name)); 
           const normalized = mappedRows.filter(r => r && r.date); 
           log(`追加广告数据：${name} → ${normalized.length.toLocaleString()} 行`, "good"); 
           AdsStore.all = AdsStore.all.concat(normalized); 
         } catch (e) { 
           log(`跳过：${name} - 无法识别为广告报表或业务报告 (${e.message})`, "bad"); 
         }
      }
      AdsStore.files.push({ name, rows: rows.length });
    } catch (err) { log(`错误：${name} 导入失败：${err?.message || err}`, "bad"); }
  }
  
  if (dedupeMode === "on" && AdsStore.all.length) { 
    const before = AdsStore.all.length; 
    AdsStore.all = dedupeRows(AdsStore.all); 
    log(`Ads 数据去重完成：${before.toLocaleString()} → ${AdsStore.all.length.toLocaleString()}`, "good"); 
  }
  if (dedupeMode === "on" && AdsStore.biz.length) { 
    const beforeBr = AdsStore.biz.length; const seenBr = new Set(); 
    AdsStore.biz = AdsStore.biz.filter(r => { 
      const key = `${r.sourceFile}|${r.asin}`; 
      if (seenBr.has(key)) return false; 
      seenBr.add(key); return true; 
    }); 
    if (beforeBr !== AdsStore.biz.length) { log(`业务报告去重完成：${beforeBr.toLocaleString()} → ${AdsStore.biz.length.toLocaleString()}`, "good"); } 
  }
  if (dedupeMode === "on" && AdsStore.placement.length) { 
    const beforePl = AdsStore.placement.length; const seenPl = new Set(); 
    AdsStore.placement = AdsStore.placement.filter(r => { 
      const key = `${r.sourceFile}|${r.date}|${r.campaign}|${r.placement}`; 
      if (seenPl.has(key)) return false; 
      seenPl.add(key); return true; 
    }); 
    if (beforePl !== AdsStore.placement.length) { log(`广告位报告去重完成：${beforePl.toLocaleString()} → ${AdsStore.placement.length.toLocaleString()}`, "good"); } 
  }

  if (AdsStore.all.length > 0) { 
    const dates = AdsStore.all.map(r => r.date).filter(Boolean).sort(); 
    $("dateStart").value = dates[0]; 
    $("dateEnd").value = dates[dates.length - 1]; 
  }
  
  buildIndexes();
  await saveToIDB();

  log(`导入完成：文件 ${AdsStore.files.length} 个`, "good");
  setSubtitle(`已导入 ${AdsStore.files.length} 个文件；Ads=${AdsStore.all.length}；Business=${AdsStore.biz.length}；Placement=${AdsStore.placement.length}`);
  
  renderFileList(); 
  populateDropdowns(); 
  applyFilters(true);
};

