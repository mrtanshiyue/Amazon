let WF_MODE = "token";
let wfSort = { key: "spend", dir: "desc" };

const IRREGULAR_NOUNS = {"men":"man","women":"woman","teeth":"tooth","feet":"foot","children":"child","running":"run","glasses":"glasses","sunglasses":"sunglasses"};
const singularize = (word) => { 
  if (!word) return ""; 
  if (IRREGULAR_NOUNS[word]) return IRREGULAR_NOUNS[word];
  if (word.endsWith("ies")) return word.slice(0, -3) + "y"; 
  if (word.endsWith("sses")) return word.slice(0, -2); 
  if (word.endsWith("ves")) return word.slice(0, -3) + "f"; 
  if (word.endsWith("s") && !word.endsWith("ss")) return word.slice(0, -1); 
