            if (filters.filterSource && r.sourceFile !== filters.filterSource) return false; if (filters.filterPortfolio && r.portfolio !== filters.filterPortfolio) return false; if (filters.filterCampaign && r.campaign !== filters.filterCampaign) return false; if (filters.filterAdGroup && r.adGroup !== filters.filterAdGroup) return false; if (filters.filterTargeting && r.targeting !== filters.filterTargeting) return false; if (filters.filterMatchType && r.matchType !== filters.filterMatchType) return false; if (!withinDate(r, filters.dateStart, filters.dateEnd)) return false;
            if (filters.filterAdType) { const isManual = checkIsManual(r); if (filters.filterAdType === "manual" && !isManual) return false; if (filters.filterAdType === "auto" && isManual) return false; }
            if (filters.filterSearchTerm) { 
                const query = filters.filterSearchTerm;
                if (filters.filterSearchExact) { if (r.searchTermLower !== query.toLowerCase()) return false; } 
                else { if (!matchAdvancedSearch(r.searchTermLower, query)) return false; } 
            }
            return true;
          });
          
          const total = sumMetrics(VIEW); 
          let bizSales = 0; for(let r of BUSINESS_ROWS) bizSales += r.sales; total.bizSales = bizSales;

          CURRENT_RANK_GROUPS = groupBy(VIEW, getRankKey());

