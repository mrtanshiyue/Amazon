const extractMagnification = (s) => { return [...String(s || "").matchAll(/(?:\+|)\b([0-6](?:\.\d{1,2})?)[xX]?\b/g)].map(m => m[1]).filter(v => !isNaN(parseFloat(v)) && parseFloat(v) > 0); };
const tokenCache = new Map();
const buildWordStats = () => {
  const minFreq = Math.max(1, Math.floor(safeNum($("wfMinFreq")?.value ?? 3))); const minSpend = Math.max(0, safeNum($("wfMinSpend")?.value ?? 10)); const mp = new Map();
