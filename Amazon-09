const uniqSorted = (arr) => Array.from(new Set(arr.filter(Boolean))).sort((a,b)=>a.localeCompare(b));
const setSingleSelectOptions = (select, values, allLabel="All") => { const cur = select.value; select.innerHTML = `<option value="">${allLabel}</option>` + values.map(v => `<option value="${v}">${v}</option>`).join(""); if ([...select.options].some(o=>o.value===cur)) select.value = cur; };
