    ctr: map.ctr ? safeNum(raw[map.ctr]) : (impr > 0 ? clicks / impr : 0), cpc: map.cpc ? safeNum(raw[map.cpc]) : (clicks > 0 ? spend / clicks : 0), cvr: map.cvr ? safeNum(raw[map.cvr]) : (clicks > 0 ? Math.min(1, orders / clicks) : 0), acos: map.acos ? safeNum(raw[map.acos]) : (sales > 0 ? spend / sales : 0), roas: map.roas ? safeNum(raw[map.roas]) : (spend > 0 ? Math.max(0, sales) / spend : 0),
