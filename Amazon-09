    sourceFile: intern(sourceFile), date: intern(toISODate(raw[map.date])), portfolio: intern(String(raw[map.portfolio] ?? "").trim()), campaign: intern(String(raw[map.campaign] ?? "").trim()), adGroup: intern(String(raw[map.adGroup] ?? "").trim()), targeting: intern(String(raw[map.targeting] ?? "").trim()), matchType: intern(String(raw[map.matchType] ?? "").trim()), searchTerm: st, searchTermLower: st.toLowerCase(), searchTermRoot: searchTermToRoot(st), impr, clicks, spend, sales: Math.max(0, sales), orders,
    ctr: map.ctr ? safeNum(raw[map.ctr]) : (impr > 0 ? clicks / impr : 0), cpc: map.cpc ? safeNum(raw[map.cpc]) : (clicks > 0 ? spend / clicks : 0), cvr: map.cvr ? safeNum(raw[map.cvr]) : (clicks > 0 ? Math.min(1, orders / clicks) : 0), acos: map.acos ? safeNum(raw[map.acos]) : acosVal, roas: map.roas ? safeNum(raw[map.roas]) : (spend > 0 ? Math.max(0, sales) / spend : 0),
