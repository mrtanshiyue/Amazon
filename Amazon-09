const sortRank = (items) => { 
    const {key, dir} = rankSort; 
    const mul = dir==="asc" ? 1 : -1; 
    items.sort((a,b)=>{ 
        const getSafeVal = (obj) => {
            const v = obj[key];
            if (key==="name"||key==="action"||key==="audit") return String(v||"");
            if (!isFinite(v)) return v === Infinity ? 999999999 : 0;
            return v ?? 0;
        };
        const av = getSafeVal(a);
        const bv = getSafeVal(b);
        if (typeof av === "string" && typeof bv === "string") return av.localeCompare(bv) * mul; 
        return (av === bv ? 0 : (av > bv ? 1 : -1)) * mul;
    }); 
};

const buildRankTable = () => { 
    const rankBy = $("rankBy").value; 
    const getMedian = (arr) => { if(!arr.length) return 0; arr.sort((a,b)=>a-b); return arr[Math.floor(arr.length/2)]; };
    const allCvrs = [], allCpcs = [], allCtrs = [], allRoas = [];
    
    for (const list of AdsStore.rankGroups.values()) {
        const m = sumMetrics(list);
        if (m.clicks >= 5) { allCvrs.push(m.smoothCvr); allCpcs.push(m.cpc); allCtrs.push(m.ctr); allRoas.push(m.roas); }
    }
    const medCtr = getMedian(allCtrs) || 0.008; 
    const medCvr = getMedian(allCvrs) || 0.05; 
    const medCpc = getMedian(allCpcs) || 1.0; 
    const medRoas = getMedian(allRoas) || 2.0;
    
    const totalSales = AdsStore.view.reduce((sum, r) => sum + r.sales, 0);
    const sortedForPareto = [...AdsStore.rankGroups.entries()].map(([name, list]) => ({name, sales: list.reduce((s, r)=>s+r.sales, 0)})).sort((a,b) => b.sales - a.sales);
    
    let cumSales = 0; const coreTerms = new Set();
    for (const item of sortedForPareto) { 
      cumSales += item.sales; coreTerms.add(item.name); 
      if (cumSales >= totalSales * 0.8) break; 
    }

    let items = [...AdsStore.rankGroups.entries()].map(([name, list]) => { 
        const base = { name, ...sumMetrics(list) }; 
        const {action, reason, suggestedBidDelta} = decideAction(base, rankBy); 
        
        let audit = "-";
        if (coreTerms.has(name) && base.roas > 0 && base.roas < (medRoas * 0.5) && base.spend > 30) { audit = "核心失血"; } 
        else if (base.clicks >= 10 && base.ctr > medCtr && base.smoothCvr < (medCvr * 0.5)) { audit = "页面缺陷"; } 
        else if (base.cpc < medCpc && base.roas > (medRoas * 1.2) && base.smoothCvr > (medCvr * 1.1) && base.orders >= 1) { audit = "潜力词"; }

        if (audit === "-" && rankBy === "searchTerm" && !isASINLike(name)) {
            const termTokens = new Set(tokenize(name)); 
            let isDrift = false;
            for (const r of list) {
                if (r.matchType && (r.matchType.toLowerCase().includes("broad") || r.matchType.toLowerCase().includes("phrase"))) {
                    if (!isASINLike(r.targeting)) {
                        const targetTokens = tokenize(r.targeting);
                        if (targetTokens.length > 0 && !targetTokens.some(t => termTokens.has(t))) { isDrift = true; break; }
                    }
                }
            }
            if (isDrift && base.clicks >= 5 && base.smoothCvr < medCvr) { audit = "匹配跑偏"; }
        }
        return { ...base, action, reason, suggestedBidDelta, audit }; 
    }); 
    if (rankTypeFilter !== "all") items = items.filter(it => detectRowType(it.name, rankBy) === rankTypeFilter); 
    sortRank(items); 
    AdsStore.rankRows = items.slice(0, clamp(safeNum($("rankTopN").value) || 30, 5, 50000));
};

