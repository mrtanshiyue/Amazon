const buildAIContext = () => {
  if (!VIEW || VIEW.length === 0) return null;
  const m = sumMetrics(VIEW);
  
  const groups = groupBy(VIEW, r => r.searchTerm);
  const terms = [...groups.entries()].map(([term, list]) => ({ term, ...sumMetrics(list) }));
  const bleeders = terms.filter(t => t.orders === 0 && t.spend > 10).sort((a,b) => b.spend - a.spend).slice(0, 5);
  
  const goldens = terms.filter(t => t.orders >= 2 && t.roas >= 3).sort((a,b) => b.roas - a.roas).slice(0, 5);
  
  const autoSpend = sumMetrics(VIEW.filter(r => !checkIsManual(r))).spend;
  const manualSpend = sumMetrics(VIEW.filter(r => checkIsManual(r))).spend;

  return {
    global: { spend: m.spend, sales: m.sales, orders: m.orders, roas: m.roas, acos: m.acos, cpc: m.cpc, cvr: m.cvr },
    structure: { autoSpendPct: m.spend > 0 ? (autoSpend/m.spend).toFixed(2) : 0 },
    bleeders: bleeders.map(b => `[${b.term}] 烧了$${b.spend.toFixed(2)} 0单`),
    goldens: goldens.map(g => `[${g.term}] ROAS ${g.roas.toFixed(2)} 花费$${g.spend.toFixed(2)}`)
  };
};

$("btnAI")?.addEventListener("click", async () => {
  // ⚡ 修复：基础混淆，防止被最简单的爬虫脚本直接抓走，提升安全性
  const apiKey = atob("QUl6YVN5Ql8ybDBXX1l6d20yT1MxWVMyeXJwWEpLMEpETmUyUzFn");

  const contextData = buildAIContext();
  if (!contextData || contextData.global.spend === 0) {
    alert("当前视图数据量不足，无法生成有效诊断。请先导入或放宽筛选条件。");
    return;
  }

  const aiBox = $("aiInsightsBox");
  const aiContent = $("aiContent");
  aiBox.style.display = "block";
  aiContent.innerHTML = `<span class="ai-loading">🔮 Gemini 正在分析 ${fmtInt(VIEW.length)} 条底层数据链路，测算美国站利润水位...</span>`;
  $("btnAI").disabled = true;

  const prompt = `
你是一位拥有 10 年经验的亚马逊美国站高级 PPC 操盘手。基于以下清洗后的广告多维数据，给出一份简明扼要、刀刀见血的诊断报告。
不要说废话，直接给出实操建议。重点关注利润率底线、词组打法降维和防流血机制。

【当前数据大盘】
总花费: $${contextData.global.spend.toFixed(2)}
总销售额: $${contextData.global.sales.toFixed(2)}
ACOS: ${(contextData.global.acos * 100).toFixed(1)}% | ROAS: ${contextData.global.roas.toFixed(2)}
全局CPC: $${contextData.global.cpc.toFixed(2)} | 全局CVR: ${(contextData.global.cvr * 100).toFixed(1)}%
自动广告花费占比: ${(contextData.structure.autoSpendPct * 100).toFixed(0)}%

【极致流血黑洞 (纯消耗0出单)】
${contextData.bleeders.length ? contextData.bleeders.join('\n') : "暂无严重流血词"}

【黄金长尾高优词 (高ROAS)】
${contextData.goldens.length ? contextData.goldens.join('\n') : "暂无沉淀出高优词"}

请输出结构：
1. 🩺 大盘定性 (1句话总结健康度)
2. ⚠️ 止血手术 (针对流血词的具体匹配与否定操作建议)
3. 🚀 蓝海放大 (针对黄金词的预算倾斜与提效动作)
4. 💡 架构微调 (根据CPC、CVR和自动广告占比给出的结构调整建议)
`;

  try {
    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }],
        generationConfig: { temperature: 0.4 } 
      })
    });

    const data = await response.json();
    if (data.error) throw new Error(data.error.message);
    
    let aiText = data.candidates[0].content.parts[0].text;
    aiText = escapeHtml(aiText).replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
    
    aiContent.innerHTML = aiText;
    log("AI 深度诊断已生成", "good");

  } catch (error) {
    console.error("Gemini API Error:", error);
    // ⚡ 修复：优雅降级，向用户提供友好的业务提示而非系统底层报错
    aiContent.innerHTML = `<span style="color:var(--warn)">⚠️ 您的 AI 参谋暂时离线 (网络连接异常或已被限流)。大盘数据已就绪，请稍后再试。</span>`;
  } finally {
    $("btnAI").disabled = false;
  }
});

