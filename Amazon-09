const normalizeBrRow = (raw, map, sourceFile) => { const sessions = safeNum(raw[map.sessions]); const units = safeNum(raw[map.units]); const sales = safeNum(raw[map.sales]); const calculatedCvr = sessions > 0 ? Math.min(1, units / sessions) : 0; const calculatedAov = units > 0 ? sales / units : 0; return { sourceFile: intern(sourceFile), asin: intern(String(raw[map.asin] ?? "").trim()), title: String(raw[map.title] ?? "").trim(), sessions, units, sales: Math.max(0, sales), cvr: isFinite(calculatedCvr) ? calculatedCvr : 0, aov: isFinite(calculatedAov) ? calculatedAov : 0 }; };

const normalizePlacementRow = (raw, map, sourceFile) => {
    if (!raw) return null; const impr = safeNum(raw[map.impr]), clicks = safeNum(raw[map.clicks]), spend = safeNum(raw[map.spend]); const sales = Math.max(0, safeNum(raw[map.sales])), orders = safeNum(raw[map.orders]); let placement = String(raw[map.placement] ?? "").trim();
