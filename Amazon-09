      }).join(" | ");
  }

  const autoSpend = sumMetrics(AdsStore.view.filter(r => !checkIsManual(r))).spend;
  let totalBizSessions = 0, totalBizUnits = 0;
  if (AdsStore.biz && AdsStore.biz.length > 0) {
