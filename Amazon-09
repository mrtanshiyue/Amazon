};

const levenshtein = (a, b) => {
    if (a === b) return 0;
    if (a.length > b.length) { let tmp = a; a = b; b = tmp; }
    let al = a.length, bl = b.length;
    if (al === 0) return bl;
    let row = Array.from({length: al + 1}, (_, i) => i);
    let res = 0;
    for (let i = 1; i <= bl; i++) {
        res = i;
        let diag = i - 1;
        for (let j = 1; j <= al; j++) {
            let cost = a[j - 1] === b[i - 1] ? 0 : 1;
            let nextDiag = row[j];
            res = Math.min(res + 1, nextDiag + 1, diag + cost);
            row[j - 1] = diag;
            diag = nextDiag;
        }
        row[al] = res;
    }
    return res;
};

const libsCheck = () => { const missing = []; if (typeof Papa === "undefined") missing.push("PapaParse"); if (typeof XLSX === "undefined") missing.push("XLSX"); if (typeof Chart === "undefined") missing.push("Chart.js"); if (typeof ExcelJS === "undefined") missing.push("ExcelJS"); if (typeof saveAs === "undefined") missing.push("FileSaver"); if (typeof idbKeyval === "undefined") missing.push("idbKeyval"); if (missing.length) log("依赖库未加载：" + missing.join(", ") + "。部分功能可能受限。", "warn"); else log("依赖库 OK", "good"); return !missing.length; };

