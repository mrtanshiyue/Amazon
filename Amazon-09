const renderLongTailMining = () => {
  const tbody = $("longTailTable")?.querySelector("tbody"); 
  if (!tbody) return; 
  if (!AdsStore.view.length) { tbody.innerHTML = ""; return; }
  
  const minWords = Math.max(1, Math.floor(safeNum($("ltMinWords").value))); 
  const minOrders = Math.max(0, Math.floor(safeNum($("ltMinOrders").value))); 
  const minRoas = safeNum($("ltMinRoas").value); 
  const groups = groupBy(AdsStore.view, r => r.searchTerm); 
  const candidates = [];
  const globalMetrics = sumMetrics(AdsStore.view); 
  const globalCpc = globalMetrics.cpc || 1.0; 
  const globalCvr = globalMetrics.cvr || 0.05;

  const margin = safeNum($("bizMargin")?.value) || 0.3;
  const ref = safeNum($("bizRef")?.value) || 0.15;
  const targetAcos = Math.max(0.15, 1 - margin - ref - 0.1); 

  for (const [term, rows] of groups.entries()) {
    if (isASINLike(term)) continue; 
    let wordCount = (term || "").replace(/-/g, " ").trim().split(/\s+/).filter(Boolean).length;
    if (term.includes("glasses") || term.includes("frame")) wordCount -= 0.5;
    if (wordCount < minWords) continue; 
    const m = sumMetrics(rows); 
    if (m.orders < minOrders) continue; 
    if (m.roas < minRoas) continue; 
    
    const cleanTerm = cleanTargetForExact(term);
    const isNewRadar = !AdsStore.indexes.exactTerm.has(cleanTerm);
    candidates.push({ term, wordCount, newRadar: isNewRadar, ...m });
  }
  candidates.sort((a,b) => b.sales - a.sales); 
  AdsStore.longTailRows = candidates; 

  if (candidates.length === 0) { 
    tbody.innerHTML = `<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:20px;">没有符合条件的长尾词（尝试降低“单词数”或“订单”门槛）</td></tr>`; 
    return;
  }
  
  renderProgressive(tbody, candidates.slice(0, 50), (c) => {
    let intentTag = "常规长尾 (Normal)";
    if (c.cpc < globalCpc * 0.8 && c.cvr > globalCvr * 1.2) intentTag = "💎 蓝海词 (低竞争高转化)";
    else if (c.cvr > globalCvr * 2) intentTag = "🎯 极强意图 (超大盘2倍)";
    const rpc = c.clicks > 0 ? c.sales / c.clicks : 0;
    const suggestedBid = rpc > 0 ? rpc * targetAcos : c.cpc;
    const tooltip = `【 ${escapeHtml(c.term)} 】${intentTag}\n转化率：${fmtPct(c.cvr)} \n建议精准出价：${fmtMoney(suggestedBid)}`;

    return `<tr title="${tooltip}"><td title="${escapeHtml(c.term)}">${escapeHtml(c.term).slice(0, 80)}</td><td>${c.newRadar ? '<span class="tag good">New Radar</span>' : '<span style="color:var(--muted)">-</span>'}</td><td>${c.wordCount}</td><td>${fmtMoney(c.spend)}</td><td>${fmtMoney(c.sales)}</td><td>${fmtInt(c.orders)}</td><td>${c.roas.toFixed(2)}</td><td style="${(c.acos > 0.4 || c.acos === Infinity) ? 'color:#b42318;font-weight:600' : ''}">${fmtPct(c.acos)}</td></tr>`;
  });
};

