                  if (filters.filterMatchType && !safeEq(r.matchType, filters.filterMatchType)) continue; 
                  
                  if (!withinDate(r, filters.dateStart, filters.dateEnd)) continue;
                  
                  if (filters.filterAdType) { 
                      const isManual = checkIsManual(r); 
                      if (filters.filterAdType === "manual" && !isManual) continue; 
                      if (filters.filterAdType === "auto" && isManual) continue; 
                  }
                  if (filters.filterSearchTerm) { 
                      const query = filters.filterSearchTerm;
                      if (filters.filterSearchExact) { 
                          if (r.searchTermLower !== query.toLowerCase()) continue; 
                      } else { 
                          if (!matchAdvancedSearch(r.searchTermLower, query)) continue; 
                      } 
                  }
                  newView.push(r);

                  if (i % 1000 === 0 && (performance.now() - lastYieldTime) > 14) {
                      await new Promise(resolve => setTimeout(resolve, 0));
                      lastYieldTime = performance.now();
                  }
              }
              return newView;
          };

          AdsStore.view = await processAsync();
          
          const total = sumMetrics(AdsStore.view); 
          let bizSales = 0; 
          for(let i = 0; i < AdsStore.biz.length; i++) bizSales = SafeMath.add(bizSales, AdsStore.biz[i].sales); 
          total.bizSales = bizSales;

          AdsStore.rankGroups = groupBy(AdsStore.view, getRankKey());

          if ($("rankBy").value === "searchTermRoot" && AdsStore.rankGroups.size > 0) {
              const rootEntries = [...AdsStore.rankGroups.entries()].map(([root, rows]) => ({root, rows, count: rows.length}));
              rootEntries.sort((a,b) => b.count - a.count); 
              const masterRoots = []; const MAX_MASTERS = 200; 
              for (const entry of rootEntries) {
                  let merged = false;
                  if (entry.root.length >= 5) {
                      const limit = Math.min(masterRoots.length, MAX_MASTERS);
                      for (let i = 0; i < limit; i++) {
                          const master = masterRoots[i];
                          if (Math.abs(master.root.length - entry.root.length) <= 1) {
                              if (levenshtein(master.root, entry.root) <= 1) { 
                                  for(let k = 0; k < entry.rows.length; k++){ master.rows.push(entry.rows[k]); }
                                  merged = true; break;
                              }
                          }
                      }
                  }
                  if (!merged) { masterRoots.push({root: entry.root, rows: [...entry.rows]}); }
              }
              AdsStore.rankGroups = new Map(masterRoots.map(m => [m.root, m.rows]));
          }

          setSubtitle(`已导入 ${AdsStore.files.length} 个文件；Ads=${AdsStore.all.length} 行；日期范围 ${filters.dateStart} → ${filters.dateEnd}`); 
          
