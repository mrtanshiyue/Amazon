const renderFileList = () => { const box = $("fileList"); box.innerHTML = importedFiles.length ? importedFiles.map(f=>` <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:6px 8px;border-radius:10px;"> <div style="font-size:12px;color:var(--text);word-break:break-all;">${escapeHtml(f.name)}</div> <div style="font-size:11.5px;color:var(--muted);white-space:nowrap;">${fmtInt(f.rows)} rows</div> </div> `).join("") : `<div class="small">暂无</div>`; };

const renderBusinessReport = () => {
    const card = $("businessReportCard"); const tbody = $("businessReportTable").querySelector("tbody");
    if (!BUSINESS_ROWS || BUSINESS_ROWS.length === 0) { card.style.display = "none"; return; } card.style.display = "block";
    const map = new Map();
    for (const r of BUSINESS_ROWS) { if (!map.has(r.asin)) { map.set(r.asin, { asin: r.asin, title: r.title, sessions: 0, units: 0, sales: 0 }); } const entry = map.get(r.asin); entry.sessions += r.sessions || 0; entry.units += r.units || 0; entry.sales += r.sales || 0; if (r.title && r.title.length > (entry.title || "").length) entry.title = r.title; }
    
    const aggregated = Array.from(map.values());
    
    // Feature 2: 计算 SPTA (广告渗透率) - 增加上限防护
    for (const r of aggregated) {
        let adOrders = 0;
        for (const adRow of VIEW) {
            if (adRow.orders > 0 && (adRow.campaign.includes(r.asin) || adRow.adGroup.includes(r.asin) || adRow.targeting.includes(r.asin) || adRow.searchTerm.includes(r.asin))) {
                adOrders += adRow.orders;
            }
        }
        r.adOrders = adOrders;
        // 核心修复1：数学上封顶至 1 (100%)，避免归因差异导致显示异常
        r.spta = r.units > 0 ? Math.min(1, adOrders / r.units) : 0;
    }
    
    aggregated.sort((a,b) => b.units - a.units);
    tbody.innerHTML = aggregated.map(r => {
        const cvr = (r.sessions > 0 && isFinite(r.sessions)) ? Math.min(1, r.units / r.sessions) : 0; 
        const aov = (r.units > 0 && isFinite(r.units)) ? r.sales / r.units : 0;
