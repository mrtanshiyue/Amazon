const truncateForAI = (arr, limit, typeName) => {
    if(arr.length <= limit) return arr.map(t => `${t.t} (消耗$${t.spend.toFixed(0)}, 产出$${(t.sales||0).toFixed(0)})`);
    const kept = arr.slice(0, limit);
    const hidden = arr.slice(limit);
    const hiddenSpend = hidden.reduce((s, x) => s + x.spend, 0);
    return [
        ...kept.map(t => `${t.t} (消耗$${t.spend.toFixed(0)}, 产出$${(t.sales||0).toFixed(0)})`),
        `...[折叠了额外 ${hidden.length} 个${typeName}，累计浪费 $${hiddenSpend.toFixed(0)}]`
    ];
};

const buildAdvancedAIContext = () => {
  if (!AdsStore.view || AdsStore.view.length === 0) return null;
  const m = sumMetrics(AdsStore.view);
  
  const stGroups = AdsStore.rankGroups || groupBy(AdsStore.view, getRankKey());
  let totalWastedSpend = 0;
  let exactSpend = 0;
  const bleeders = []; 
  const golden = [];   
  const broadAutoLeaks = []; 

  for (const [t, list] of stGroups.entries()) {
      if (isASINLike(t) || !t || t === "(blank)") continue;
      const tm = sumMetrics(list);
      
      const isExact = list.some(r => (r.matchType || "").toLowerCase().includes("exact"));
      if (isExact) exactSpend = SafeMath.add(exactSpend, tm.spend);
      else broadAutoLeaks.push({t, ...tm});

      if (tm.orders === 0 && tm.spend > 0) {
          totalWastedSpend = SafeMath.add(totalWastedSpend, tm.spend);
          if (tm.spend > 15) bleeders.push({t, ...tm});
      }
      if (tm.orders >= 3 && tm.roas >= 3) {
          golden.push({t, ...tm});
      }
  }

  bleeders.sort((a,b) => b.spend - a.spend);
  golden.sort((a,b) => b.sales - a.sales);
  broadAutoLeaks.sort((a,b) => b.spend - a.spend);

  const topTerms = [...stGroups.entries()]
      .filter(([t]) => !isASINLike(t) && t !== "(blank)")
      .map(([t, list]) => ({t, ...sumMetrics(list)}))
      .sort((a,b) => b.spend - a.spend)
      .slice(0, 50)
      .map(x => `${x.t} (Spend:$${x.spend.toFixed(0)}, Orders:${x.orders}, CVR:${(x.cvr*100).toFixed(1)}%)`);

  let placementStats = "无广告位数据导入。";
