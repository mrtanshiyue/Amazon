const wireCascade = () => {
  const updateChildDropdowns = (currentFilterId, childFilterIds, mapFns) => { const filters = ["filterSource", "filterPortfolio", "filterCampaign"].reduce((acc, id) => ({ ...acc, [id]: $(id).value }), {}); let rows = ALL; for (const key in filters) if (filters[key]) rows = rows.filter(r => r[key.replace("filter", "").toLowerCase()] === filters[key]); childFilterIds.forEach((childId, i) => setSingleSelectOptions($(childId), uniqSorted(rows.map(mapFns[i])))); autoApply(); };
  $("filterSource").onchange = () => { ["filterPortfolio", "filterCampaign", "filterAdGroup", "filterTargeting", "filterMatchType"].forEach(id => ($(id).value = "")); populateDropdowns(); autoApply(); };
  $("filterPortfolio").onchange = () => updateChildDropdowns("filterPortfolio", ["filterCampaign", "filterAdGroup"], [r => r.campaign, r => r.adGroup]); $("filterCampaign").onchange = () => updateChildDropdowns("filterCampaign", ["filterAdGroup"], [r => r.adGroup]);
};

const withinDate = (r, start, end) => (!start || r.date >= start) && (!end || r.date <= end);

const sumMetrics = (rows) => {
  let impr=0, clicks=0, spendCents=0, salesCents=0, orders=0, units=0;
  for (const r of rows) { 
      impr += r.impr; clicks += r.clicks; orders += r.orders; 
      spendCents += Math.round(r.spend * 100); 
      salesCents += Math.max(0, Math.round(r.sales * 100)); 
      units += (r.orders || 0) * 1.1; 
  }
  const spend = spendCents / 100; const sales = salesCents / 100;
  
  const marginRate = safeNum($("bizMargin")?.value) || 0.3;
  const fbaFee = safeNum($("bizFba")?.value) || 4.5;
  const referralFeeRate = safeNum($("bizRef")?.value) || 0.15;

  const cogs = sales * marginRate;
  const fbaFees = units * fbaFee;
  const referralFees = sales * referralFeeRate;
  const netProfit = sales - spend - cogs - fbaFees - referralFees;

  const cvr = clicks > 0 ? Math.min(1, orders / clicks) : 0;
  const smoothCvr = clicks > 0 ? (orders + 15 * 0.05) / (clicks + 15) : 0;
  
  return { 
      impr, clicks, spend, sales, orders, netProfit,
      ctr: impr > 0 ? clicks / impr : 0, 
      cpc: clicks > 0 ? spend / clicks : 0, 
      cvr, smoothCvr, 
      acos: sales > 0 ? spend / sales : (spend > 0 ? Infinity : 0), 
      roas: spend > 0 ? Math.max(0, sales) / spend : 0 
  };
};

const groupBy = (rows, keyFn) => { const mp = new Map(); for (const r of rows) { const k = keyFn(r) || "(blank)"; (mp.has(k) ? mp : mp.set(k, [])).get(k).push(r); } return mp; };

const detectAnomalies = (rows) => {
    const container = $("anomalyAlerts"); if (!container) return; if (!rows || rows.length === 0) { container.style.display = "none"; container.innerHTML = ""; return; }
    const alerts = []; const groups = CURRENT_RANK_GROUPS || groupBy(rows, r => r.searchTerm); let topBleeder = null; let maxWasted = 0;
    
    let score = 100;
    const totalMetrics = sumMetrics(rows);
    let bizSales = 0; let bizUnits = 0;
    for(let r of BUSINESS_ROWS) { bizSales += r.sales; bizUnits += r.units; }
    
    let globalSpta = 0; let globalTacos = 0;
    if (bizUnits > 0) {
        globalSpta = totalMetrics.orders / bizUnits;
        globalTacos = totalMetrics.spend / bizSales;
        if (globalSpta > 0.8) score -= 30;
        if (globalTacos > 0.25) score -= 15;
    } else {
        score -= 20; 
    }
    
    if (totalMetrics.netProfit < 0) score -= 40;
    if (totalMetrics.acos > 0.4) score -= 10;
    score = Math.max(0, score);

    let healthHtml = '';
    if (score >= 80) healthHtml = `🟢 结构健康 (Score: ${score}) - 净利正向且自然流量充足。`;
    else if (score >= 50) healthHtml = `🟡 中度承压 (Score: ${score}) - 利润受压或对广告过度依赖。`;
    else healthHtml = `🔴 极高风险 (Score: ${score}) - 严重依赖广告且面临系统性亏损，建议即刻止血！`;

    alerts.unshift({ type: score < 50 ? 'bad' : (score < 80 ? 'warn' : 'good'), msg: `<strong>📊 综合生意体检评分：</strong> ${healthHtml}` });

    for (const [term, list] of groups.entries()) { if (isASINLike(term)) continue; let spend = 0, orders = 0; for (const r of list) { spend += r.spend; orders += r.orders; } if (orders === 0 && spend > maxWasted) { maxWasted = spend; topBleeder = term; } }
    if (maxWasted > 30) { alerts.push({ type: 'bad', msg: `<strong>🚨 极端浪费预警：</strong> 核心词 <code>${escapeHtml(topBleeder)}</code> 在当前时间段内花费高达 <strong>$${maxWasted.toFixed(2)}</strong> 且 0 转化，建议立即排查相关性或加入否定！` }); }
    
    const adGroupGroups = groupBy(rows, r => `${r.campaign}|${r.adGroup}`);
    for (const [ag, list] of adGroupGroups.entries()) {
        const stSet = new Set(list.map(r=>r.searchTerm).filter(Boolean));
        const m = sumMetrics(list);
        if (stSet.size > 50 && (m.clicks / stSet.size) < 1.5 && m.spend > 20 && m.roas < 1.0) {
            alerts.push({ type: 'warn', msg: `<strong>🌪️ 流量熵值失控：</strong> 广告组 <code>${escapeHtml(ag.split('|')[1])}</code> 触发了 ${stSet.size} 个碎片化无效搜索词，建议添加词组否定或降低竞价！` });
            break; 
        }
    }

    const campGroups = groupBy(rows, r => r.campaign);
    for (const [camp, list] of campGroups.entries()) {
        const stMap = groupBy(list, r=>r.searchTerm);
        const termStats = [...stMap.entries()].map(([t, rs])=>({t, spend:sumMetrics(rs).spend})).sort((a,b)=>b.spend-a.spend);
        const totalCSpend = sumMetrics(list).spend;
        if (termStats.length > 20 && totalCSpend > 50) {
            const head20Spend = termStats.slice(0, Math.ceil(termStats.length * 0.2)).reduce((s, x)=>s+x.spend, 0);
            if (head20Spend < totalCSpend * 0.4 && sumMetrics(list).roas < 1.0) {
                 alerts.push({ type: 'warn', msg: `<strong>🌪️ 帕累托耗散预警：</strong> 计划 <code>${escapeHtml(camp)}</code> 头部 20% 词仅占不到 40% 花费，长尾严重吸血，建议调低基础出价！` });
                 break; 
            }
        }
    }

    if (alerts.length > 0) { container.innerHTML = alerts.map(a => `<div class="alert-banner ${a.type === 'warn' ? 'warn' : (a.type === 'good' ? 'good' : '')}"> <span class="alert-icon">${a.type === 'warn' ? '⚠️' : (a.type === 'good' ? '✨' : '🚨')}</span> <div>${a.msg}</div> </div>`).join(""); container.style.display = "flex"; } else { container.style.display = "none"; container.innerHTML = ""; }
};

