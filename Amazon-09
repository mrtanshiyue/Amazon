const dedupeRows = (rows) => { const seen = new Set(), out = []; for (const r of rows) { const key = `${r.date}|${r.campaign}|${r.adGroup}|${r.targeting}|${r.matchType}|${r.searchTerm}`; if (!seen.has(key)) { seen.add(key); out.push(r); } } return out; };
const importMultipleFiles = async (files) => {
  clearLog(); if (!libsCheck()) return; const mergeMode = $("mergeMode").value, dedupeMode = $("dedupeMode").value; const maxRows = clamp(safeNum($("maxRows").value) || 500000, 10000, 2000000);
  log(`开始导入：${files.length} 个文件（merge=${mergeMode}, dedupe=${dedupeMode}, maxRows=${maxRows}）`); setSubtitle("正在进行多线程数据处理与洗刷...请稍候");
  
