let WF_MODE = "token";
let wfSort = { key: "spend", dir: "desc" };
const singularize = (word) => { if (!word) return ""; if (word === "glasses" || word === "sunglasses") return word; if (word.endsWith("ies")) return word.slice(0, -3) + "y"; if (word.endsWith("sses")) return word.slice(0, -2); if (word.endsWith("ves")) return word.slice(0, -3) + "f"; if (word.endsWith("s") && !word.endsWith("ss")) return word.slice(0, -1); return word; };
