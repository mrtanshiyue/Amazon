      ALL = []; BUSINESS_ROWS = []; PLACEMENT_ROWS = []; importedFiles = []; rootCache.clear(); tokenCache.clear(); stringPool = Object.create(null); poolSize = 0; CURRENT_RANK_GROUPS = null; ISOLATION_ROWS = [];
      try { await idbKeyval.clear(); } catch(e) {} 
      log("Replace 模式：已清空历史数据与缓存分片", "warn"); 
  }
  
  for (const file of files) {
    const name = file.name, lower = name.toLowerCase(); log(`读取文件：${name}`);
    try {
      let rows = [];
      if (lower.endsWith(".csv")) { log(`解析 CSV：${name}`); rows = await parseCSV(file); } else if (lower.endsWith(".xlsx") || lower.endsWith(".xls")) { log(`解析 XLSX/XLS：${name}`); rows = await parseXLSX(file); } else { log(`跳过：不支持的文件类型（${name}）`, "warn"); continue; }
      rows = rows.filter(r => r && Object.keys(r).length > 0);
      if (!rows.length) { log(`警告：${name} 解析后为空`, "warn"); continue; }
      if (rows.length > maxRows) { log(`警告：${name} 行数 ${rows.length.toLocaleString()} 超过 maxRows，将截断`, "warn"); rows = rows.slice(0, maxRows); }
      
      const header = Object.keys(rows[0]); const normHeader = header.map(cleanHeader);
      const hasAsin = normHeader.some(h => ["（子）asin", "(child)asin", "childasin", "子商品asin"].includes(h));
      const hasSessions = normHeader.some(h => ["会话数-总计", "sessions-total", "sessions", "买家访问次数"].includes(h));
      const hasPlacement = normHeader.some(h => ["放置", "placement"].includes(h));
      const hasSearchTerm = normHeader.some(h => ["客户搜索词", "customersearchterm", "searchterm"].includes(h));

      if (hasAsin && hasSessions) {
         log(`>> 检测到业务报告 (Business Report) 格式`, "good"); const brMap = buildBrMap(rows); const mappedRows = await processInChunks(rows, r => normalizeBrRow(r, brMap, name)); const norm = mappedRows.filter(r => r.asin); BUSINESS_ROWS = BUSINESS_ROWS.concat(norm); log(`导入业务报告：${name} → ${norm.length.toLocaleString()} 行`, "good");
      } else if (hasPlacement && !hasSearchTerm) { 
         log(`>> 检测到广告位报告 (Placement Report) 格式`, "good"); const plMap = buildPlacementMap(rows); const mappedRows = await processInChunks(rows, r => normalizePlacementRow(r, plMap, name)); const norm = mappedRows.filter(r => r.placement); PLACEMENT_ROWS = PLACEMENT_ROWS.concat(norm); log(`导入广告位报告：${name} → ${norm.length.toLocaleString()} 行`, "good");
      } else {
         try { const map = buildMap(rows); log(`标准化字段 + 提取时序特征：${name}`); const mappedRows = await processInChunks(rows, r => normalizeRow(r, map, name)); const normalized = mappedRows.filter(r => r && r.date); log(`追加广告数据：${name} → ${normalized.length.toLocaleString()} 行`, "good"); ALL = ALL.concat(normalized); } catch (e) { log(`跳过：${name} - 无法识别为广告报表或业务报告 (${e.message})`, "bad"); }
      }
      importedFiles.push({ name, rows: rows.length });
    } catch (err) { log(`错误：${name} 导入失败：${err?.message || err}`, "bad"); }
  }
  
  if (dedupeMode === "on" && ALL.length) { const before = ALL.length; ALL = dedupeRows(ALL); log(`Ads 数据去重完成：${before.toLocaleString()} → ${ALL.length.toLocaleString()}`, "good"); }
  if (dedupeMode === "on" && BUSINESS_ROWS.length) { const beforeBr = BUSINESS_ROWS.length; const seenBr = new Set(); BUSINESS_ROWS = BUSINESS_ROWS.filter(r => { const key = `${r.sourceFile}|${r.asin}`; if (seenBr.has(key)) return false; seenBr.add(key); return true; }); if (beforeBr !== BUSINESS_ROWS.length) { log(`业务报告去重完成：${beforeBr.toLocaleString()} → ${BUSINESS_ROWS.length.toLocaleString()}`, "good"); } }
  if (dedupeMode === "on" && PLACEMENT_ROWS.length) { const beforePl = PLACEMENT_ROWS.length; const seenPl = new Set(); PLACEMENT_ROWS = PLACEMENT_ROWS.filter(r => { const key = `${r.sourceFile}|${r.date}|${r.campaign}|${r.placement}`; if (seenPl.has(key)) return false; seenPl.add(key); return true; }); if (beforePl !== PLACEMENT_ROWS.length) { log(`广告位报告去重完成：${beforePl.toLocaleString()} → ${PLACEMENT_ROWS.length.toLocaleString()}`, "good"); } }

  if (ALL.length > 0) { const dates = ALL.map(r => r.date).filter(Boolean).sort(); $("dateStart").value = dates[0]; $("dateEnd").value = dates[dates.length - 1]; }
  
  await saveToIDB();

  log(`导入完成：文件 ${importedFiles.length} 个`, "good");
  setSubtitle(`已导入 ${importedFiles.length} 个文件；Ads=${ALL.length}；Business=${BUSINESS_ROWS.length}；Placement=${PLACEMENT_ROWS.length}`);
  renderFileList(); populateDropdowns(); applyFilters(true);
};
