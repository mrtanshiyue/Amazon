const normalizeRow = (raw, map, sourceFile) => {
  if (!raw) return null; const impr = safeNum(raw[map.impr]), clicks = safeNum(raw[map.clicks]), spend = safeNum(raw[map.spend]); const sales = safeNum(raw[map.sales7d]), orders = safeNum(raw[map.orders7d]); const st = String(raw[map.searchTerm] ?? "").trim();
