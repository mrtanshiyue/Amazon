  log(`开始导入：${files.length} 个文件（merge=${mergeMode}, dedupe=${dedupeMode}, maxRows=${maxRows}）`); setSubtitle("正在导入文件…（请看左侧导入日志）");
  
  if (mergeMode === "replace") { ALL = []; BUSINESS_ROWS = []; PLACEMENT_ROWS = []; importedFiles = []; rootCache.clear(); tokenCache.clear(); stringPool.clear(); CURRENT_RANK_GROUPS = null; log("Replace 模式：已清空历史数据与缓存", "warn"); }
  
  for (const file of files) {
