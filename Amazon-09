};
const detectRowType = (name, rankBy) => (rankBy === "searchTerm" || rankBy === "searchTermRoot" || rankBy === "targeting") ? (isASINLike(name) ? "asin" : "keyword") : "other";

const checkIsManual = (r) => {
    const lowerMatch = (r.matchType||"").toLowerCase();
