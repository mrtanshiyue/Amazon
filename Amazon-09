const isASINLike = (s) => {
  const x = String(s || "").trim(); if (!x) return false; if (x.length < 10) return false; const candidates = x.match(/[A-Z0-9]{10}/ig); if (!candidates) return false;
  for (const c of candidates) { if (/^[B0-9][A-Z0-9]{9}$/i.test(c) && /\d/.test(c)) return true; }
  return /asin\s*=\s*[A-Z0-9]{10}/i.test(x) || /asin\s*:\s*[A-Z0-9]{10}/i.test(x);
};
const detectRowType = (name, rankBy) => (rankBy === "searchTerm" || rankBy === "searchTermRoot" || rankBy === "targeting") ? (isASINLike(name) ? "asin" : "keyword") : "other";

const checkIsManual = (r) => {
    const lowerMatch = (r.matchType||"").toLowerCase();
    const lowerTargeting = (r.targeting||"").toLowerCase();
    if (["broad", "phrase", "exact"].includes(lowerMatch)) return true;
    if (lowerTargeting === "*" || ["close-match", "loose-match", "substitutes", "complements"].includes(lowerTargeting)) return false;
    if (isASINLike(lowerTargeting) || lowerTargeting.includes("category") || lowerTargeting.includes("asin")) return true;
    return lowerMatch.includes("product") || lowerMatch.includes("targeting");
};

let ALL = [], VIEW = [], importedFiles = [], trendChart = null; let trafficChart = null; let BUSINESS_ROWS = []; let PLACEMENT_ROWS = []; let rankSort = { key: "spend", dir: "desc" }; let RANK_ROWS = [], rankTypeFilter = "all"; let LONG_TAIL_ROWS = [];

