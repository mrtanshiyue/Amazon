const renderBusinessReport = () => {
    const card = $("businessReportCard"); 
    const tbody = $("businessReportTable").querySelector("tbody");
    if (!AdsStore.biz || AdsStore.biz.length === 0) { card.style.display = "none"; return; } 
    card.style.display = "block";
    
    const map = new Map();
    for (const r of AdsStore.biz) { 
      if (!map.has(r.asin)) { map.set(r.asin, { asin: r.asin, title: r.title, sessions: 0, units: 0, sales: 0 }); } 
      const entry = map.get(r.asin); 
      entry.sessions += r.sessions || 0; entry.units += r.units || 0; entry.sales += r.sales || 0; 
      if (r.title && r.title.length > (entry.title || "").length) entry.title = r.title; 
    }
    
    const aggregated = Array.from(map.values());
    
    for (const r of aggregated) {
        let adOrders = 0;
        for (const adRow of AdsStore.view) {
            if (adRow.orders > 0 && (adRow.campaign.includes(r.asin) || adRow.adGroup.includes(r.asin) || adRow.targeting.includes(r.asin) || adRow.searchTerm.includes(r.asin))) {
                adOrders += adRow.orders;
            }
        }
        r.adOrders = adOrders;
        r.spta = r.units > 0 ? Math.min(1, adOrders / r.units) : 0;
    }
    
    aggregated.sort((a,b) => b.units - a.units);
    
    renderProgressive(tbody, aggregated, (r) => {
        const cvr = (r.sessions > 0 && isFinite(r.sessions)) ? Math.min(1, r.units / r.sessions) : 0; 
        const aov = (r.units > 0 && isFinite(r.units)) ? r.sales / r.units : 0;
        
        let lifecycle = "稳定期";
        let lifecycleHtml = `<span style="color:var(--muted)">稳定期</span>`;
        if (r.sessions < 1000) {
            lifecycle = "新品期";
            lifecycleHtml = `<span class="tag good">新品推广期</span>`;
        } else if (r.sessions > 10000 && r.units < r.sessions * 0.01) {
            lifecycle = "衰退期";
            lifecycleHtml = `<span class="tag bad">衰退期/清仓</span>`;
        } else if (r.sessions > 5000) {
            lifecycle = "成熟期";
            lifecycleHtml = `<span class="tag" style="background:#0a84ff; color:#fff">成熟收割期</span>`;
        }
        r.lifecycle = lifecycle; 
        
        let sptaHtml = fmtPct(r.spta);
        if (r.spta > 0.8 && lifecycle !== "新品期") {
            sptaHtml = `<span style="color:var(--bad);font-weight:bold" title="成熟期预警：自然流量枯竭！">${fmtPct(r.spta)}</span>`;
        } else if (r.spta > 0.8 && lifecycle === "新品期") {
            sptaHtml = `<span style="color:var(--warn);" title="新品推广期，高占比属于正常行为">${fmtPct(r.spta)}</span>`;
        }
        
        const isZombie = r.sessions < 5 && r.units === 0;
        const displayAsin = isZombie ? `<span style="color:var(--bad);text-decoration:line-through;" title="流量枯竭 (近乎0曝光)">${escapeHtml(r.asin)}</span> <span class="tag bad" style="padding:2px 4px;font-size:10px">僵尸</span>` : `<span style="font-weight:600; color:var(--text);">${escapeHtml(r.asin)}</span>`;

