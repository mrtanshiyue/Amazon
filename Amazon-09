    while (html.includes('<chart-config>') && html.includes('</chart-config>')) {
        const startTag = '<chart-config>';
        const endTag = '</chart-config>';
        const startIdx = html.indexOf(startTag);
        const endIdx = html.indexOf(endTag) + endTag.length;
        
        const block = html.substring(startIdx, endIdx);
        const jsonStr = block.replace(startTag, '').replace(endTag, '').replace(/<[^>]+>/g, '').replace(/&quot;/g, '"');
        
        try {
            const config = JSON.parse(jsonStr);
            const canvasId = 'ai-chart-' + Math.random().toString(36).substr(2, 9);
            const replacement = `<div class="ai-chart-container"><canvas id="${canvasId}"></canvas></div>`;
            html = html.replace(block, replacement);
            
            setTimeout(() => {
                const ctx = $(canvasId)?.getContext('2d');
                if (ctx) {
                    new Chart(ctx, {
                        type: config.type || 'bar',
                        data: config,
                        options: { responsive: true, maintainAspectRatio: false }
                    });
                }
            }, 100);
        } catch (e) {
            console.error("AI Chart Parsing Error", e);
            html = html.replace(block, `<div class="tag bad">图表 JSON 渲染失败，可能是大模型格式出错</div>`);
        }
    }
    bubble.innerHTML = html;
};

