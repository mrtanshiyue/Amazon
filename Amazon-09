const renderIsolationAnalysis = () => {
  const tbody = $("isolationTable")?.querySelector("tbody"); 
  if (!tbody) return; 
  if (!VIEW.length) { tbody.innerHTML = ""; return; }

  const minOrders = Math.max(1, Math.floor(safeNum($("isoMinOrders")?.value || 3)));
  
  const exactPool = new Set();
  for (const r of ALL) {
    if ((r.matchType || "").toLowerCase().includes("exact")) {
      // ⚡ 修复：同上，保留空格，精确判断隔离状态
      const cleanTarget = cleanTargetForExact(r.targeting);
      if (cleanTarget) exactPool.add(cleanTarget);
    }
  }

  const nonExactMap = new Map();
  for (const r of VIEW) {
    if (!r.searchTerm || isASINLike(r.searchTerm)) continue;
    const matchLower = (r.matchType || "").toLowerCase();
    const isExact = matchLower.includes("exact");
    
    if (!isExact) {
      if (!nonExactMap.has(r.searchTerm)) {
        nonExactMap.set(r.searchTerm, { term: r.searchTerm, sources: new Set(), rows: [] });
      }
      const entry = nonExactMap.get(r.searchTerm);
      entry.sources.add(matchLower || "auto");
      entry.rows.push(r);
    }
  }

  const candidates = [];
  for (const [term, data] of nonExactMap.entries()) {
    const m = sumMetrics(data.rows);
    if (m.orders >= minOrders) {
      const cleanTerm = cleanTargetForExact(term);
      const isIsolated = exactPool.has(cleanTerm);
      
      if (!isIsolated) {
        candidates.push({
          term: term,
          source: Array.from(data.sources).join(", "),
          isIsolated: false,
          ...m
        });
      }
    }
  }

  candidates.sort((a, b) => b.sales - a.sales);
  ISOLATION_ROWS = candidates;

  if (candidates.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--muted)">🎉 太棒了！所有符合条件的高转化词均已完成精准隔离（或当前筛选无达标数据）。</td></tr>`;
    return;
  }

  tbody.innerHTML = candidates.slice(0, 50).map(c => {
    return `<tr>
      <td style="font-weight:600;color:var(--text)">${escapeHtml(c.term)}</td>
      <td style="color:var(--muted);text-transform:capitalize;">${escapeHtml(c.source)}</td>
      <td><span class="tag bad">未提取 (Un-isolated)</span></td>
      <td>${fmtMoney(c.spend)}</td>
      <td>${fmtInt(c.orders)}</td>
      <td><span style="color:var(--good);font-weight:600">${c.roas.toFixed(2)}</span></td>
      <td><span style="font-size:11px;font-weight:600;color:var(--accent);">提取 Exact + 原组否定</span></td>
    </tr>`;
  }).join("");
};

