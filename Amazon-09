const pickCol = (header, aliases) => { const normHeader = header.map(cleanHeader); for (const a of aliases) { const target = cleanHeader(a); const idx = normHeader.indexOf(target); if (idx >= 0) return header[idx]; } return null; };
const buildMap = (rows) => { const header = rows.length ? Object.keys(rows[0]) : []; const map = {}; for (const key in COL_MAP_ALIASES) map[key] = pickCol(header, COL_MAP_ALIASES[key]); if (!map.date) throw new Error("Ads Report: 未找到日期列 (Date)."); return map; };
