                            aiFullText += textPart;
                            bubble.innerHTML = aiFullText.replace(/```html/g, '').replace(/```/g, '');
                            $("aiChatHistory").scrollTop = $("aiChatHistory").scrollHeight;
                        }
                    } catch (e) { 
                        console.warn("SSE Parse Error", e); 
                    }
                }
            }
        }
        
        processAICharts(bubble);
        
        aiMessageHistory.push({ role: "user", parts: [{ text: finalPrompt }] });
        aiMessageHistory.push({ role: "model", parts: [{ text: aiFullText }] });

        if (isInitialReport) {
            $("btnAILog").style.display = "inline-flex";
            $("btnAIPDF").style.display = "inline-flex";
            $("btnAIBulk").style.display = "inline-flex";
        }

    } catch (error) {
        console.error("Gemini API Streaming Error:", error);
        bubble.innerHTML = `<div class="alert-banner">⚠️ 流式连接中断。请检查网络或稍后再试。</div>`;
    } finally {
        $("btnSendAI").disabled = false;
        $("aiChatInput").disabled = false;
        $("aiChatInput").focus();
    }
};

const bindAIEvents = () => {
    $("btnAI")?.addEventListener("click", async () => {
        const contextString = buildAdvancedAIContext();
        if (!contextString) {
            alert("当前视图数据量不足，无法生成有效的高阶诊断。请先导入数据。");
            return;
        }

        currentSystemContext = contextString;
        aiMessageHistory = []; 
        $("aiChatHistory").innerHTML = ""; 
        
        const aiBox = $("aiInsightsBox");
        aiBox.style.display = "block";
        $("btnAI").disabled = true;

        const initialPrompt = `请对当前大盘进行一次全面的综合体检报告。请严格按照以下 4 个模块输出（使用 <h3> 标签）：\n1. 🧭 核心体检与趋势定调\n2. 🩸 止血手术清单 (Negation & Downbidding)\n3. 🚀 结构重组与拓词建议 (Search Term Isolation)\n4. 💡 针对即将到来的 Spring Sale (春季大促) 的预算操盘指令`;
        
        await callGeminiChatAPI(initialPrompt, true);
        $("btnAI").disabled = false;
    });

    $("btnSendAI")?.addEventListener("click", () => {
        const inputObj = $("aiChatInput");
        const msg = inputObj.value.trim();
        if (!msg) return;
        
        inputObj.value = "";
        inputObj.disabled = true;
        $("btnSendAI").disabled = true;
        
        const userBubble = createChatBubble("user");
        userBubble.innerHTML = `<strong>我:</strong> ${escapeHtml(msg)}`;
        callGeminiChatAPI(msg);
    });

    $("aiChatInput")?.addEventListener("keypress", (e) => {
        if (e.key === "Enter") {
            e.preventDefault();
            $("btnSendAI").click();
        }
    });

    $("btnCloseAI")?.addEventListener("click", () => { $("aiInsightsBox").style.display = "none"; });

    $("btnAILog")?.addEventListener("click", () => {
        if (aiMessageHistory.length === 0) return;
        let logText = `=== Ads Dashboard Pro 交互对话日志 ===\n生成时间: ${new Date().toLocaleString()}\n操作人: 亚马逊高级运营专家\n==================================\n\n`;
        
        aiMessageHistory.forEach(msg => {
            const role = msg.role === "user" ? "【运营指令】" : "【Gemini AI】";
            const plainText = msg.parts[0].text.replace(/<[^>]+>/g, '').replace(/&lt;/g, '<').replace(/&gt;/g, '>');
            logText += `${role}\n${plainText}\n\n`;
        });

        const blob = new Blob([logText], { type: "text/plain;charset=utf-8" });
        if (window.saveAs) {
            window.saveAs(blob, `Ultimate_AI_Chat_Log_${getTs()}.txt`);
        }
    });

    $("btnAIPDF")?.addEventListener("click", async () => {
        const btn = $("btnAIPDF");
        const originalText = btn.innerHTML;
        const element = $("aiChatHistory"); 
        
        if (!element || element.children.length === 0) return;

        btn.innerHTML = "⏳ 正在渲染 PDF...";
        btn.disabled = true;

        const exportToPDF = async () => {
            const currentTheme = document.documentElement.getAttribute("data-theme") || "light";
            const bgColors = { light: '#ffffff', dark: '#242426', ocean: '#1e293b', forest: '#1b241b', sepia: '#eee8d5' };

            const opt = {
                margin:       [12, 12, 15, 12], 
                filename:     `Ultimate_AI_Diagnosis_${getTs()}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 }, 
                html2canvas:  { 
                    scale: window.devicePixelRatio > 1 ? 2 : 1.5, 
                    useCORS: true, 
                    logging: false,
                    backgroundColor: bgColors[currentTheme] || '#ffffff'
                },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            try {
                await html2pdf().set(opt).from(element).save();
            } catch (err) {
                console.error("PDF Export Core Crash:", err);
                alert("PDF 渲染引擎遇到执行阻塞，请稍后重试。");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        };

        if (typeof window.html2pdf === 'undefined') {
            const script = document.createElement('script');
            script.src = "https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js";
            script.onload = () => { exportToPDF(); };
            script.onerror = () => { 
                alert("无法加载 PDF 引擎，请检查网络策略(CORS)或代理。"); 
                btn.innerHTML = originalText; 
                btn.disabled = false; 
            };
            document.head.appendChild(script);
        } else { 
            exportToPDF(); 
        }
    });

    $("btnAIBulk")?.addEventListener("click", () => {
        const bulkHeaders = ["Product", "Entity", "Operation", "Campaign Id", "Ad Group Id", "Portfolio Id", "Ad Id", "Keyword Id", "Product Targeting Id", "Campaign Name", "Ad Group Name", "Keyword Text", "Match Type", "Bidding Strategy", "Placement", "Percentage", "Bid", "State"];
        const bulkRows = [];

        const r = getRules();
        const groups = AdsStore.rankGroups || groupBy(AdsStore.view, getRankKey());

        const globalMetrics = sumMetrics(AdsStore.view);
        const globalCvr = globalMetrics.cvr || 0.05;
        const expectedClicksForOneOrder = globalCvr > 0 ? (1 / globalCvr) : 20;

        for (const [term, list] of groups.entries()) {
            if (!term || term === "(blank)" || isASINLike(term)) continue;

            const m = sumMetrics(list);
            const mainRow = list.reduce((prev, curr) => (curr.spend > prev.spend) ? curr : prev, list[0]);
            let cleanTerm = (term || "").replace(/\s+/g, " ").trim();
            
            const safeCampaign = mainRow.campaign || "(请填入 Campaign 名称)";
            const safeAdGroup = mainRow.adGroup || "(请填入 Ad Group 名称)";

            if (m.spend >= r.spendNeg && m.clicks > (expectedClicksForOneOrder * 1.5) && m.orders === 0) {
                bulkRows.push([
                    "Sponsored Products", "Negative Keyword", "Create", 
                    "", "", "", "", "", "", 
                    safeCampaign, safeAdGroup, cleanTerm, "negative exact", 
                    "", "", "", "", "enabled"
                ]);
            }
            else if (m.roas >= r.roasKeep && m.orders >= r.ordersKeep) {
                const isAlreadyExact = list.some(row => (row.matchType || "").toLowerCase() === "exact");
                if (!isAlreadyExact) {
                    const suggestedBid = m.cpc > 0 ? (m.cpc * 1.2).toFixed(2) : 0.5; 
                    bulkRows.push([
                        "Sponsored Products", "Keyword", "Create", 
                        "", "", "", "", "", "", 
                        safeCampaign, safeAdGroup, cleanTerm, "exact", 
                        "", "", "", suggestedBid, "enabled"
                    ]);
                }
            }
        }

        if (bulkRows.length === 0) {
            alert("当前视图未检测到符合自动止血/提价规则的词汇，无需导出。可尝试在左侧放宽判定规则。");
            return;
        }

        exportRichExcelMultiSheet([{ 
            sheetName: "Sponsored Products Campaigns", 
            headers: bulkHeaders, 
            dataRows: bulkRows 
        }], `Bulk_Operations_AI_Action_${getTs()}.xlsx`).then(() => {
            log(`已生成 Bulk 批量执行表 (共包含 ${bulkRows.length} 条操作指令)`, "good");
        });
    });
};

const THEMES = ['light', 'dark', 'ocean', 'forest', 'sepia'];
const THEME_LABELS = { light: '🎨 主题: 浅色 (Light)', dark: '🎨 主题: 深色 (Dark)', ocean: '🎨 主题: 海洋 (Ocean)', forest: '🎨 主题: 森林 (Forest)', sepia: '🎨 主题: 护眼 (Sepia)' };
const initThemeButton = () => { const currentTheme = document.documentElement.getAttribute("data-theme") || "light"; $("btnTheme").textContent = THEME_LABELS[currentTheme] || THEME_LABELS.light; };
const toggleTheme = () => { 
  const currentTheme = document.documentElement.getAttribute("data-theme") || "light"; 
  const currentIndex = THEMES.indexOf(currentTheme); 
  const nextIndex = (currentIndex + 1) % THEMES.length; 
  const newTheme = THEMES[nextIndex]; 
  document.documentElement.setAttribute("data-theme", newTheme); 
  localStorage.setItem("theme", newTheme); 
  $("btnTheme").textContent = THEME_LABELS[newTheme]; 
  if (trendChart && typeof trendChart.update === 'function') { 
    if ((AdsStore.view && AdsStore.view.length) || (AdsStore.all && AdsStore.all.length)) 
      renderTrend(AdsStore.view || AdsStore.all); 
  } 
};

return {
  init: () => {
    initIDB();
    bindEvents();
    bindAIEvents();
    initThemeButton();
    $("btnTheme").addEventListener("click", toggleTheme);
  }
};

})();

window.addEventListener('load', AdsDashboardApp.init);
</script>
</body>
</html>
