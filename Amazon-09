const regexCache = new Map();
const matchAdvancedSearch = (term, query) => {
    if (query.startsWith("regex:")) { 
        let re = regexCache.get(query);
        if (!re) {
            try { re = new RegExp(query.slice(6), "i"); regexCache.set(query, re); } catch(e){ return false; }
        }
        return re.test(term);
    }
    const positive = [], negative = [];
    query.toLowerCase().split(/\s+/).forEach(q => { 
      if(q.startsWith("-") && q.length > 1) negative.push(q.slice(1)); 
      else if (q) positive.push(q); 
    });
    for (const n of negative) { if (term.includes(n)) return false; }
    for (const p of positive) { if (!term.includes(p)) return false; }
    return true;
};

