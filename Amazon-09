              const rootEntries = [...CURRENT_RANK_GROUPS.entries()].map(([root, rows]) => ({root, rows, count: rows.length}));
              rootEntries.sort((a,b) => b.count - a.count); 
              const masterRoots = []; const MAX_MASTERS = 200; 
              for (const entry of rootEntries) {
                  let merged = false;
                  if (entry.root.length >= 5) {
                      const limit = Math.min(masterRoots.length, MAX_MASTERS);
                      for (let i = 0; i < limit; i++) {
                          const master = masterRoots[i];
                          if (Math.abs(master.root.length - entry.root.length) <= 1) {
                              if (levenshtein(master.root, entry.root) <= 1) { 
                                  for(let k = 0; k < entry.rows.length; k++){ master.rows.push(entry.rows[k]); }
                                  merged = true; break;
                              }
                          }
                      }
                  }
                  if (!merged) { masterRoots.push({root: entry.root, rows: [...entry.rows]}); }
              }
              CURRENT_RANK_GROUPS = new Map(masterRoots.map(m => [m.root, m.rows]));
          }

          setSubtitle(`已导入 ${importedFiles.length} 个文件；Ads=${ALL.length} 行；日期范围 ${filters.dateStart} → ${filters.dateEnd}`); 
