const renderConflictAnalysis = () => {
  const tbody = $("conflictTable")?.querySelector("tbody"); if (!tbody) return; if (!VIEW.length) { tbody.innerHTML = ""; return; }
  const map = new Map();
  for (const r of VIEW) {
    if (!r.searchTerm || isASINLike(r.searchTerm)) continue; 
    const loc = `${r.campaign} > ${r.adGroup}`;
    if (!map.has(r.searchTerm)) { map.set(r.searchTerm, { locMap: new Map(), spend: 0, orders: 0, sales: 0 }); }
    const entry = map.get(r.searchTerm);
    entry.locMap.set(loc, (entry.locMap.get(loc) || 0) + r.spend);
    entry.spend += r.spend; entry.orders += r.orders; entry.sales += r.sales;
  }
  const conflicts = [];
  for (const [term, data] of map.entries()) {
    const activeLocs = Array.from(data.locMap.entries()).filter(([l, sp]) => sp > 2.0).map(x => x[0]);
    if (activeLocs.length > 1 && data.spend > 5) {
      conflicts.push({ term, count: activeLocs.length, locs: activeLocs, spend: data.spend, orders: data.orders, roas: data.spend > 0 ? data.sales / data.spend : 0 });
    }
  }
  conflicts.sort((a,b) => b.spend - a.spend);
  if (conflicts.length === 0) { tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--muted)">未检测到明显的内部竞争（条件：至少在 2 个不同广告组中分别消耗 > $2）</td></tr>`; return; }
  tbody.innerHTML = conflicts.slice(0, 50).map(c => {
    const displayLocs = c.locs.slice(0, 2).map(l => `<div style="font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escapeHtml(l)}</div>`).join(""); const moreCount = c.locs.length > 2 ? `<div style="font-size:10px;color:var(--muted)">+${c.locs.length - 2} more...</div>` : ""; const fullLocs = c.locs.join("\n");
    return `<tr data-term="${escapeHtml(c.term)}" style="cursor:pointer" title="点击筛选该词"><td style="font-weight:600;color:var(--text)">${escapeHtml(c.term)}</td><td><span class="tag bad" style="font-size:11px">${c.count}个</span></td><td title="${escapeHtml(fullLocs)}">${displayLocs}${moreCount}</td><td>${fmtMoney(c.spend)}</td><td>${fmtInt(c.orders)}</td><td>${c.roas.toFixed(2)}</td></tr>`;
  }).join("");
};
$("conflictTable").addEventListener("click", (e) => { const tr = e.target.closest("tr"); if (!tr || !tr.dataset.term) return; $("filterSearchTerm").value = tr.dataset.term; applyFilters(); });

const getRules = () => ({ spendNeg: safeNum($("ruleSpendNeg").value), clicksNeg: Math.max(0, Math.floor(safeNum($("ruleClicksNeg").value))), roasNeg: safeNum($("ruleRoasNeg").value), roasKeep: safeNum($("ruleRoasKeep").value), ordersKeep: Math.max(0, Math.floor(safeNum($("ruleOrdersKeep").value))), roasMigrateMin: safeNum($("ruleRoasMigrateMin").value) });
const decideAction = (item, rankBy) => {
  const r = getRules(); const reasons = [];
  const condNeg1 = item.spend >= r.spendNeg && item.orders <= 0; if (condNeg1) reasons.push(`无转化且花费≥${r.spendNeg}`);
  const condNeg2 = item.clicks >= r.clicksNeg && (item.orders <= 0 || item.roas < r.roasNeg); if (condNeg2) reasons.push(`点击量≥${r.clicksNeg}且(无单或ROAS<${r.roasNeg})`);
  
  if (condNeg1 || condNeg2) return { action:"NEGATE", reason: reasons.join(" • ") };
  reasons.length = 0;
  const condKeep1 = item.roas >= r.roasKeep && item.spend > 0; if (condKeep1) reasons.push(`ROAS≥${r.roasKeep}`); const condKeep2 = item.orders >= r.ordersKeep; if (condKeep2) reasons.push(`订单数≥${r.ordersKeep}`);
  if (condKeep1 || condKeep2) return { action:"KEEP", reason: reasons.join(" • ") };
  if (item.orders > 0 && item.roas >= r.roasMigrateMin && item.roas < r.roasKeep) return { action:"MIGRATE", reason: `订单数>0 & ROAS≥${r.roasMigrateMin} & <${r.roasKeep}` };
  return { action:"KEEP", reason:"无风险信号" };
};

const exportNegativesCSV = () => {
  const rankBy = $("rankBy").value; if (!["searchTerm", "searchTermRoot"].includes(rankBy)) { log("导出失败：只有在榜单维度为 Search Term / Root 时才允许导出否定词", "bad"); alert("导出失败：请将“榜单聚合维度”切换为 Search Term 或 Search Term Root，再导出否定词。"); return; } if (!VIEW.length) { log("导出失败：当前视图为空", "bad"); alert("导出失败：当前视图为空。"); return; }
  const itemsToExport = $("exportScope").value === "rank" ? RANK_ROWS.slice() : (() => { return [...(CURRENT_RANK_GROUPS || new Map()).entries()].map(([name, list]) => { const it = { name, ...sumMetrics(list) }; const a = decideAction(it, rankBy); return { ...it, action:a.action, reason:a.reason }; }).sort((a,b)=> (b.spend||0) - (a.spend||0)); })();
  const rows = [["关键词","否定匹配","分组维度","理由","花费","销售额","订单数","ROAS","ACOS"]]; const seen = new Set(); const defaultNegMatch = $("exportNegMatch").value.toUpperCase();
  for (const it of itemsToExport) {
    if (it.action !== "NEGATE") continue; let keyword = (rankBy === "searchTermRoot" ? rootToPhrase(it.name) : String(it.name || "").trim()).replace(/\s+/g," ").trim(); if (!keyword || keyword === "(blank)") continue;
    let finalMatchType = defaultNegMatch; if (isASINLike(keyword)) { finalMatchType = "NEGATIVE TARGETING"; }
    const key = `${finalMatchType}:${keyword.toLowerCase()}`; if (!seen.has(key)) { seen.add(key); rows.push([ keyword, finalMatchType, (rankBy === "searchTerm" ? "客户搜索词" : "搜索词根"), it.reason || "", (it.spend ?? 0).toFixed(2), (it.sales ?? 0).toFixed(2), String(it.orders ?? 0), (it.roas ?? 0).toFixed(2), ((it.acos ?? 0) * 100).toFixed(2) + "%" ]); }
  }
  if (rows.length === 1) { log("未找到可导出的 NEGATE 项（请调低阈值或扩大日期范围）", "warn"); alert("未找到可导出的 NEGATE 项（请调低阈值或扩大日期范围）。"); return; } const filename = `negatives_${rankBy}_${defaultNegMatch}_${$("dateStart").value || "start"}_${$("dateEnd").value || "end"}_${getTs()}.csv`; downloadText(filename, toCSV(rows)); log(`已导出否定词 CSV：${filename}（${rows.length-1} 条）`, "good");
};

const exportRankCSV = () => { if (!RANK_ROWS.length) { alert("当前榜单为空，无数据可导出。"); return; } const headers = ["Name", "Audit", "Spend", "Sales", "Orders", "Impressions", "Clicks", "CTR", "CPC", "CVR", "ACOS", "ROAS", "Action", "Reason"]; const rows = [headers]; for (const r of RANK_ROWS) { rows.push([ r.name, r.audit, (r.spend || 0).toFixed(2), (r.sales || 0).toFixed(2), r.orders, r.impr, r.clicks, ((r.ctr || 0) * 100).toFixed(2) + "%", (r.cpc || 0).toFixed(2), ((r.cvr || 0) * 100).toFixed(2) + "%", ((r.acos || 0) * 100).toFixed(2) + "%", (r.roas || 0).toFixed(2), r.action, r.reason ]); } const filename = `rank_list_${$("dateStart").value || "start"}_${$("dateEnd").value || "end"}_${getTs()}.csv`; downloadText(filename, toCSV(rows)); log(`已导出榜单 CSV：${filename}（${rows.length-1} 条）`, "good"); };

const renderKPIs = (total) => {
  const kpis = [ { key: "spend", label:"花费", value: fmtMoney(total.spend), meta: `点击成本 ${fmtMoney(total.cpc)} • 点击率 ${fmtPct(total.ctr)}` }, { key: "sales", label:"销售额 (7天)", value: fmtMoney(total.sales), meta: `ROAS ${total.roas.toFixed(2)} • ACOS ${fmtPct(total.acos)}` }, { key: "orders", label:"订单数 (7天)", value: fmtInt(total.orders), meta: `转化率 ${fmtPct(total.cvr)} • 点击量 ${fmtInt(total.clicks)}` }, { key: "impr", label:"展示量", value: fmtInt(total.impr), meta: `点击量 ${fmtInt(total.clicks)} • 点击率 ${fmtPct(total.ctr)}` }, { key: "acos", label:"ACOS", value: fmtPct(total.acos), meta: `花费/销售额` }, { key: "roas", label:"ROAS", value: total.roas.toFixed(2), meta: `销售额/花费` }, { key: "cpc", label:"点击成本", value: fmtMoney(total.cpc), meta: `花费/点击量` }, { key: "cvr", label:"转化率", value: fmtPct(total.cvr), meta: `订单数/点击量` } ];
  $("kpiGrid").innerHTML = kpis.map(k => ` <div class="card kpi"> <div class="label"><span>${k.label}</span><span class="pill">KPI</span></div> <div class="value">${k.value}</div> <div class="meta"><span>${k.meta}</span></div> </div> `).join("");
};
const renderTrend = (rows) => {
  if (!rows || rows.length === 0) return; const byDate = groupBy(rows, r=>r.date); const series = [...byDate.keys()].sort().map(d=>({ date:d, ...sumMetrics(byDate.get(d)) })); const dataMap = (key, transform = v => v) => series.map(s => transform(s[key])); const gridColor = getComputedStyle(document.documentElement).getPropertyValue('--chart-grid').trim() || "rgba(229,229,234,.6)"; const acosData = series.map(s => { if (s.sales <= 0 && s.spend > 0) return null; return s.acos * 100; });
  const datasets = [ { label:"花费", data:dataMap("spend"), tension:.25, pointRadius:0, borderWidth:2 }, { label:"销售额", data:dataMap("sales"), tension:.25, pointRadius:0, borderWidth:2 }, { label:"订单数", data:dataMap("orders"), tension:.25, pointRadius:0, borderWidth:2 }, { label:"ACOS %", data:acosData, tension:.25, pointRadius:0, borderWidth:2, yAxisID:"y1", spanGaps: true }, { label:"ROAS", data:dataMap("roas", v => isFinite(v) ? v : 0), tension:.25, pointRadius:0, borderWidth:2, yAxisID:"y1" } ];
  if (trendChart) { trendChart.destroy(); trendChart = null; } const canvas = $("trendChart");
  if (canvas) { const ctx = canvas.getContext("2d"); try { trendChart = new Chart(ctx, { type:"line", data:{ labels:series.map(s=>s.date), datasets }, options:{ responsive:true, maintainAspectRatio:false, interaction:{ mode:"index", intersect:false }, scales:{ y:{ beginAtZero:true, grid:{ color: gridColor } }, y1:{ beginAtZero:true, position:"right", grid:{ drawOnChartArea:false } }, x:{ grid:{ display:false } } } } }); } catch(e) { console.error("Chart Error", e); } }
};
const getRankKey = () => { const mapping = { searchTerm: r => r.searchTerm || "(空白)", searchTermRoot: r => r.searchTermRoot || "(空白)", targeting: r => r.targeting || "(空白)", campaign: r => r.campaign || "(空白)", adGroup: r => r.adGroup || "(空白)", }; return mapping[$("rankBy").value]; };

const sortRank = (items) => { 
    const {key, dir} = rankSort; 
    const mul = dir==="asc" ? 1 : -1; 
    items.sort((a,b)=>{ 
        const av = key==="name"||key==="action"||key==="audit" ? String(a[key]||"") : (a[key] ?? 0); 
        const bv = key==="name"||key==="action"||key==="audit" ? String(b[key]||"") : (b[key] ?? 0); 
        if (typeof av === "string" && typeof bv === "string") return av.localeCompare(bv) * mul; 
        return (av === bv ? 0 : (av > bv ? 1 : -1)) * mul;
    }); 
};

const buildRankTable = () => { 
    const rankBy = $("rankBy").value; 
    
    // 核心修复3：获取当前视图下的大盘均值，作为流量审计的动态标尺
    const globalMetrics = VIEW.length ? sumMetrics(VIEW) : { ctr: 0.008, cvr: 0.05, cpc: 1.0, roas: 3.0 };
    const avgCtr = globalMetrics.ctr || 0.008;
    const avgCvr = globalMetrics.cvr || 0.05;
    const avgCpc = globalMetrics.cpc || 1.0;
    const avgRoas = globalMetrics.roas || 3.0;

    let items = [...(CURRENT_RANK_GROUPS || new Map()).entries()].map(([name, list]) => { 
        const base = { name, ...sumMetrics(list) }; 
        const {action, reason} = decideAction(base, rankBy); 
        
        let audit = "-";
        // 动态判定逻辑：
        if (base.clicks >= 10 && base.ctr > avgCtr && base.cvr < (avgCvr * 0.5)) {
            audit = "页面缺陷";
        } else if (base.cpc < avgCpc && base.roas > (avgRoas * 1.2) && base.orders >= 1) {
            audit = "潜力词";
        }
        
        return { ...base, action, reason, audit }; 
    }); 
    if (rankTypeFilter !== "all") items = items.filter(it => detectRowType(it.name, rankBy) === rankTypeFilter); 
    sortRank(items); 
    RANK_ROWS = items.slice(0, clamp(safeNum($("rankTopN").value) || 30, 5, 500)); 
};

const renderRankTable = () => { 
    buildRankTable(); 
    const searchBtnHtml = `<span class="action-icon search-btn" title="精准搜索">🔍</span>`; 
    $("rankTable").querySelector("tbody").innerHTML = RANK_ROWS.map(it => {
        const auditHtml = it.audit === '页面缺陷' ? '<span class="tag bad">页面缺陷</span>' : (it.audit === '潜力词' ? '<span class="tag good">潜力词</span>' : '<span style="color:var(--muted)">-</span>');
        return ` <tr> <td title="${escapeHtml(it.name)}" data-name="${escapeHtml(it.name)}">${escapeHtml(it.name).slice(0, 160)}${searchBtnHtml}</td> <td>${auditHtml}</td> <td>${fmtMoney(it.spend)}</td> <td>${fmtMoney(it.sales)}</td> <td>${fmtInt(it.orders)}</td> <td>${fmtInt(it.impr)}</td> <td>${fmtInt(it.clicks)}</td> <td>${fmtPct(it.ctr)}</td> <td>${fmtMoney(it.cpc)}</td> <td>${fmtPct(it.cvr)}</td> <td style="${it.acos > 0.4 ? 'color:#b42318;' : ''}">${fmtPct(it.acos)}</td> <td>${it.roas.toFixed(2)}</td> </tr> `;
    }).join(""); 
};

const applyFilters = (initial=false) => {
  if (!ALL.length && !BUSINESS_ROWS.length && !PLACEMENT_ROWS.length) { setSubtitle("未导入数据。请导入同类报表（支持多文件）。"); $("kpiGrid").innerHTML = ""; if (trendChart) { trendChart.destroy(); trendChart = null; } if (trafficChart) { trafficChart.destroy(); trafficChart = null; } $("rankTable").querySelector("tbody").innerHTML = ""; $("anomalyAlerts").style.display = "none"; renderRankTable(); renderWordFreq(); renderLongTailMining(); renderWeekdayAnalysis(); renderCPCDistribution(); renderLengthAnalysis(); renderMatchTypeAnalysis(); renderConflictAnalysis(); renderBusinessReport(); renderTrafficSegmentation(); renderPlacementAnalysis(); return; }
  setSubtitle("🔄 正在深度分析与聚合数据，请稍候...");
  setTimeout(() => {
      try {
          const filters = { dateStart: $("dateStart").value, dateEnd: $("dateEnd").value, filterSource: $("filterSource").value, filterPortfolio: $("filterPortfolio").value, filterCampaign: $("filterCampaign").value, filterAdGroup: $("filterAdGroup").value, filterTargeting: $("filterTargeting").value, filterMatchType: $("filterMatchType").value, filterAdType: $("filterAdType").value, filterSearchTerm: $("filterSearchTerm").value.trim(), filterSearchExact: $("filterSearchExact").checked };
          VIEW = ALL.filter(r => {
            if (filters.filterSource && r.sourceFile !== filters.filterSource) return false; if (filters.filterPortfolio && r.portfolio !== filters.filterPortfolio) return false; if (filters.filterCampaign && r.campaign !== filters.filterCampaign) return false; if (filters.filterAdGroup && r.adGroup !== filters.filterAdGroup) return false; if (filters.filterTargeting && r.targeting !== filters.filterTargeting) return false; if (filters.filterMatchType && r.matchType !== filters.filterMatchType) return false; if (!withinDate(r, filters.dateStart, filters.dateEnd)) return false;
            if (filters.filterAdType) {
                const isManual = checkIsManual(r);
                if (filters.filterAdType === "manual" && !isManual) return false;
                if (filters.filterAdType === "auto" && isManual) return false;
            }
            if (filters.filterSearchTerm) { const term = filters.filterSearchTerm.toLowerCase(); if (filters.filterSearchExact) { if (r.searchTermLower !== term) return false; } else { if (!r.searchTermLower.includes(term)) return false; } }
            return true;
          });
          const total = sumMetrics(VIEW); CURRENT_RANK_GROUPS = groupBy(VIEW, getRankKey());
          if (ALL.length > 0) { setSubtitle(`已导入 ${importedFiles.length} 个文件；Ads=${ALL.length}；Business=${BUSINESS_ROWS.length}；Placement=${PLACEMENT_ROWS.length}；日期范围 ${filters.dateStart} → ${filters.dateEnd}`); } else { setSubtitle(`已导入 ${importedFiles.length} 个文件；Ads=${ALL.length}；Business=${BUSINESS_ROWS.length}；Placement=${PLACEMENT_ROWS.length}`); }
          requestAnimationFrame(() => { renderKPIs(total); detectAnomalies(VIEW); renderTrend(VIEW); renderRankTable(); renderWordFreq(); renderLongTailMining(); renderWeekdayAnalysis(); renderCPCDistribution(); renderAutoManual(); renderLengthAnalysis(); renderMatchTypeAnalysis(); renderConflictAnalysis(); renderBusinessReport(); renderPlacementAnalysis(); renderTrafficSegmentation(); if (initial) { document.querySelectorAll(".chipBtn").forEach(b => b.classList.remove("active")); document.querySelector('.chipBtn[data-range="all"]')?.classList.add("active"); } });
      } catch (e) { console.error("Critical Error in applyFilters:", e); }
  }, 20); 
};

const autoApply = debounce(applyFilters, 200);
const applyQuickRange = (type) => { const datesData = ALL.length > 0 ? ALL : PLACEMENT_ROWS; if (!datesData.length) return; const dates = datesData.map(r=>r.date).filter(Boolean).sort(); const [minD, maxD] = [dates[0], dates[dates.length-1]]; if (type === "all") { $("dateStart").value = minD; $("dateEnd").value = maxD; return; } const max = new Date(maxD); let start = new Date(max); const rangeMap = { yesterday: () => start.setDate(start.getDate()-1), "7d": () => start.setDate(start.getDate()-6), "30d": () => start.setDate(start.getDate()-29), "mtd": () => start.setDate(1) }; if(rangeMap[type]) rangeMap[type](); const isoStart = toISODate(start); $("dateStart").value = isoStart < minD ? minD : isoStart; $("dateEnd").value = maxD; };

$("fileInput").addEventListener("change", async (e)=>{ const files = Array.from(e.target.files || []); if (files.length) { log("文件选择事件触发"); await importMultipleFiles(files); e.target.value = ""; } });
const filterIds = ["dateStart","dateEnd","filterSource","filterPortfolio","filterCampaign","filterAdGroup","filterTargeting","filterMatchType","rankBy","rankTopN","ruleSpendNeg","ruleClicksNeg","ruleRoasNeg","ruleRoasKeep","ruleOrdersKeep","ruleRoasMigrateMin","exportScope","exportNegMatch","wfMinFreq","wfMinSpend","ltMinWords","ltMinOrders","ltMinRoas","filterSearchExact","filterAdType", "brandNameInput"];
filterIds.forEach(id => $(id)?.addEventListener("change", autoApply));
$("filterSearchTerm").addEventListener("input", debounce(applyFilters, 280)); $("brandNameInput").addEventListener("input", debounce(applyFilters, 400)); 
$("btnClearSearch").addEventListener("click", () => { $("filterSearchTerm").value = ""; $("filterSearchExact").checked = false; $("filterSearchTerm").focus(); applyFilters(); });
$("btnReset").addEventListener("click", () => { ["filterSource","filterPortfolio","filterCampaign","filterAdGroup","filterTargeting","filterMatchType","filterSearchTerm", "filterAdType", "brandNameInput"].forEach(id => ($(id).value = "")); $("rankBy").value = "searchTerm"; rankSort = { key:"spend", dir:"desc" }; populateDropdowns(); applyFilters(); });
$("btnClearAll").addEventListener("click", () => { ALL = []; VIEW = []; BUSINESS_ROWS = []; PLACEMENT_ROWS = []; importedFiles = []; rootCache.clear(); tokenCache.clear(); stringPool.clear(); CURRENT_RANK_GROUPS = null; renderFileList(); populateDropdowns(); applyFilters(true); });

document.querySelectorAll(".chipBtn").forEach(btn => { btn.addEventListener("click", () => { document.querySelectorAll(".sidebar .chipBtn").forEach(b => b.classList.remove("active")); btn.classList.add("active"); applyQuickRange(btn.dataset.range); applyFilters(); }); });
$("rankTable").querySelectorAll("thead th").forEach(th => th.addEventListener("click", () => { const key = th.dataset.sort; if (!key) return; rankSort = (rankSort.key === key) ? {key, dir: (rankSort.dir === "desc" ? "asc" : "desc")} : {key, dir:"desc"}; renderRankTable(); }));
$("rankTable").addEventListener("click", (e) => { if (e.target.classList.contains("search-btn")) { const td = e.target.closest("td"); const term = td.getAttribute("data-name"); if (term) { $("filterSearchTerm").value = term; $("filterSearchExact").checked = true; applyFilters(); $(".sidebar").scrollTop = 0; } } });
$("wfTable").querySelectorAll("thead th").forEach(th => th.addEventListener("click", () => { const key = th.dataset.sort; if(!key) return; wfSort = (wfSort.key === key) ? {key, dir: (wfSort.dir === "desc" ? "asc" : "desc")} : {key, dir:"desc"}; renderWordFreq(); }));
document.addEventListener("click", (e) => { const btn = e.target.closest(".segBtn"); if (!btn) return; if (btn.dataset.type) setTypeFilter(btn.dataset.type); if (btn.dataset.wf) { WF_MODE = btn.dataset.wf; document.querySelectorAll('.seg[aria-label="Word Frequency Mode"] .segBtn').forEach(b => b.classList.toggle("active", b.dataset.wf === WF_MODE)); renderWordFreq(); } });

const setTypeFilter = (t) => { rankTypeFilter = t; document.querySelectorAll('.seg[aria-label="Type Filter"] .segBtn').forEach(b => b.classList.toggle("active", b.dataset.type === t)); renderRankTable(); };
$("btnExportWf").addEventListener("click", exportWordFreqCSV); $("btnExportNeg").addEventListener("click", exportNegativesCSV); $("btnExportLongTail").addEventListener("click", exportLongTailCSV); $("btnExportRank").addEventListener("click", exportRankCSV);
$("btnRuleReset").addEventListener("click", () => { $("ruleSpendNeg").value = 30; $("ruleClicksNeg").value = 20; $("ruleRoasNeg").value = 1.5; $("ruleRoasKeep").value = 3; $("ruleOrdersKeep").value = 2; $("ruleRoasMigrateMin").value = 2; applyFilters(); });
$("btnCheck").addEventListener("click", () => { if(libsCheck()) alert("所有依赖库加载正常！"); });

const THEMES = ['light', 'dark', 'ocean', 'forest', 'sepia'];
const THEME_LABELS = { light: '🎨 主题: 浅色 (Light)', dark: '🎨 主题: 深色 (Dark)', ocean: '🎨 主题: 海洋 (Ocean)', forest: '🎨 主题: 森林 (Forest)', sepia: '🎨 主题: 护眼 (Sepia)' };
const initThemeButton = () => { const currentTheme = document.documentElement.getAttribute("data-theme") || "light"; $("btnTheme").textContent = THEME_LABELS[currentTheme] || THEME_LABELS.light; };
const toggleTheme = () => { const currentTheme = document.documentElement.getAttribute("data-theme") || "light"; const currentIndex = THEMES.indexOf(currentTheme); const nextIndex = (currentIndex + 1) % THEMES.length; const newTheme = THEMES[nextIndex]; document.documentElement.setAttribute("data-theme", newTheme); localStorage.setItem("theme", newTheme); $("btnTheme").textContent = THEME_LABELS[newTheme]; if (trendChart && typeof trendChart.update === 'function') { if ((VIEW && VIEW.length) || (ALL && ALL.length)) renderTrend(VIEW || ALL); } };
$("btnTheme").addEventListener("click", toggleTheme);

renderFileList(); populateDropdowns(); applyFilters(true); initThemeButton();
</script>
</body>
