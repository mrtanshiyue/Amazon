    if (!raw) return null; const impr = safeNum(raw[map.impr]), clicks = safeNum(raw[map.clicks]), spend = safeNum(raw[map.spend]); const sales = Math.max(0, safeNum(raw[map.sales])), orders = safeNum(raw[map.orders]); let placement = String(raw[map.placement] ?? "").trim();
