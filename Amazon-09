};

const tokenize = (s) => { const base = normalizeTextBase(s); return base.split(" ").filter(t => { if (!t) return false; if (STOP_WORDS.has(t)) return false; if (/^\d+$/.test(t)) return false; return true; }).map(t => singularize(t)); };
