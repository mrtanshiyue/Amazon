const toISODate = (d) => {
  if (typeof d === "number" && isFinite(d)) { 
    const dateObj = new Date(Math.round((d - 25569) * 86400000)); 
    return `${dateObj.getUTCFullYear()}-${String(dateObj.getUTCMonth()+1).padStart(2,'0')}-${String(dateObj.getUTCDate()).padStart(2,'0')}`; 
  }
  const s = String(d || "").trim();
  if (!s) return "";
  const isoMatch = s.match(/^(\d{4})[-\/.](\d{1,2})[-\/.](\d{1,2})/);
  if (isoMatch) return `${isoMatch[1]}-${isoMatch[2].padStart(2,'0')}-${isoMatch[3].padStart(2,'0')}`;
  const euMatch = s.match(/^(\d{1,2})[-\/.](\d{1,2})[-\/.](\d{4})/);
  if (euMatch) {
      const p1 = parseInt(euMatch[1], 10), p2 = parseInt(euMatch[2], 10), y = parseInt(euMatch[3], 10);
      let m = p1, day = p2; if (p1 > 12) { day = p1; m = p2; }
      return `${y}-${String(m).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
  }
  const dt = new Date(s); 
  if (!isNaN(dt.getTime())) return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
  return ""; 
};

const levenshtein = (a, b) => {
    if (a === b) return 0;
    if (a.length > b.length) { let tmp = a; a = b; b = tmp; }
    let al = a.length, bl = b.length;
    if (al === 0) return bl;
    let row = Array.from({length: al + 1}, (_, i) => i);
    let res = 0;
    for (let i = 1; i <= bl; i++) {
        res = i;
        let diag = i - 1;
        for (let j = 1; j <= al; j++) {
            let cost = a[j - 1] === b[i - 1] ? 0 : 1;
            let nextDiag = row[j];
            res = Math.min(res + 1, nextDiag + 1, diag + cost);
            row[j - 1] = diag;
            diag = nextDiag;
        }
        row[al] = res;
    }
    return res;
};

