const normalizeTextBase = (s) => { let x = String(s ?? "").toLowerCase().replace(/[\u2010-\u2015]/g, "-"); for(let i=0; i<SYNONYM_MAP.length; i++) x = x.replace(SYNONYM_MAP[i].re, SYNONYM_MAP[i].to); for(let i=0; i<PHRASE_REGEXES.length; i++) x = x.replace(PHRASE_REGEXES[i].re, PHRASE_REGEXES[i].to); return x.replace(/[^a-z0-9._\s]/g, " ").replace(/\s+/g, " ").trim(); };

const rootCache = new Map();
const searchTermToRoot = (term) => { if (!term) return "(blank)"; if (rootCache.has(term)) return rootCache.get(term); const base = normalizeTextBase(term); const mags = [...(base.match(MAG_RE) || [])].map(n => parseFloat(n.replace(/[xX]/g, ''))).filter(n => n > 0 && n <= 6).map(String); const tokens = base.split(" ").filter(Boolean); const kept = tokens.filter(t => !(/^\d+(\.\d+)?$/.test(t) || STOP_WORDS.has(t) || (t.length > 4 && t.endsWith("s") && (t=t.slice(0,-1))))); const root = [...new Set(kept), ...new Set(mags.map(v=>`+${v}`))].join(" | ").trim(); const res = root || "(blank)"; if (rootCache.size > CONFIG.CACHE_MAX) { rootCache.clear(); } rootCache.set(term, res); return res; };
