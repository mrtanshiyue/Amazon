const parseXLSX = (file) => new Promise((r,j)=>{ const reader = new FileReader(); reader.onload = (e)=>{try{const wb=XLSX.read(new Uint8Array(e.target.result),{type:"array"});r(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:""}));}catch(err){j(err);}}; reader.onerror = j; reader.readAsArrayBuffer(file); });
