const decideAction = (item, rankBy) => {
    const r = getRules(); 
    let action = "KEEP"; let reason = "观察中"; let suggestedBidDelta = "0%";

    const endDateStr = $("dateEnd")?.value;
    const isWithinAttributionWindow = endDateStr ? ((new Date() - new Date(endDateStr)) / 86400000 <= 14) : true;
    const isStrictAttribution = endDateStr ? ((new Date() - new Date(endDateStr)) / 86400000 <= 3) : false; 
    const isEventProtection = $("eventProtectionToggle")?.checked; 
    
    let lifecycleAdjustment = 1.0;
    if (AdsStore.biz && AdsStore.biz.length > 0 && item.campaign) {
        const matchedBr = AdsStore.biz.find(b => item.campaign.includes(b.asin));
        if (matchedBr && matchedBr.lifecycle === "新品期") lifecycleAdjustment = 1.5; 
        if (matchedBr && matchedBr.lifecycle === "衰退期") lifecycleAdjustment = 0.8; 
    }

    const dynamicSpendNeg = (isWithinAttributionWindow ? (r.spendNeg * 1.5) : r.spendNeg) * lifecycleAdjustment;
    
    const globalMetrics = sumMetrics(AdsStore.view);
    const globalCvr = globalMetrics.cvr || 0.05;
    const expectedClicksForOneOrder = globalCvr > 0 ? (1 / globalCvr) : 20;

    if (item.spend >= dynamicSpendNeg && item.clicks > (expectedClicksForOneOrder * 1.5) && item.orders <= 0) {
        if (isStrictAttribution || isEventProtection) {
            action = "WATCH"; 
            reason = isEventProtection ? `大促蓄水期保护 (防算法误杀, 净亏 $${Math.abs(item.netProfit || 0).toFixed(2)})` : `近期数据归因延迟保护`;
            suggestedBidDelta = "0%";
        } else {
            action = "NEGATE"; 
            reason = isWithinAttributionWindow ? `归因期内高消耗且无点击效能 (净亏 $${Math.abs(item.netProfit || 0).toFixed(2)})` : `深度流血且点击量远超大盘阈值 (净亏 $${Math.abs(item.netProfit || 0).toFixed(2)})`;
            suggestedBidDelta = "-100%";
        }
    } else if (item.roas >= (r.roasKeep / lifecycleAdjustment) && item.netProfit > 10) {
        action = "SCALE"; reason = `正向盈利 (+$${item.netProfit.toFixed(2)})`;
        suggestedBidDelta = "+20%"; 
    } else if (item.roas > 1 && item.netProfit < 0) {
        action = "DECREASE"; reason = `ROAS达标但净利为负`;
        suggestedBidDelta = "-15%"; 
    } else if (item.orders > 0 && item.roas < r.roasKeep) {
        action = "MIGRATE"; reason = `有单但效率低`;
        suggestedBidDelta = "-10%";
    } else if (item.spend >= dynamicSpendNeg && item.orders <= 0) {
        action = "DECREASE"; reason = `高客单点击，暂不否定，建议降价`;
        suggestedBidDelta = "-30%";
    }

    let placementBoost = "";
    if (AdsStore.placement.length > 0 && item.campaign) {
        const campPlacements = AdsStore.placement.filter(p => p.campaign === item.campaign);
        if (campPlacements.length > 0) {
            const tos = sumMetrics(campPlacements.filter(p => p.placement.includes("Top of Search")));
            const ros = sumMetrics(campPlacements.filter(p => p.placement.includes("Rest of Search")));
            if (tos.clicks > 10 && ros.clicks > 10 && ros.cvr > 0 && tos.cvr > ros.cvr * 1.5) {
                placementBoost = ` | TOS溢价建议 +${Math.round((tos.cvr/ros.cvr - 1)*100)}%`;
            }
        }
    }
    suggestedBidDelta += placementBoost;

    return { action, reason, suggestedBidDelta };
};

const exportRichExcelMultiSheet = async (sheets, filename) => {
    const wrap = $("globalProgressWrap");
    const bar = $("globalProgressBar");
    if (wrap) wrap.style.display = "block";
    
    const workbook = new ExcelJS.Workbook(); 
    workbook.creator = 'Ads Dashboard Pro'; 
    workbook.created = new Date();
    
    let totalRows = 0;
    sheets.forEach(s => totalRows += s.dataRows.length);
    let processedRows = 0;

    for (const { sheetName, headers, dataRows, freezeRow = 1 } of sheets) {
        const safeSheetName = String(sheetName).slice(0, 30).replace(/[\\/?*[\]]/g, '');
        const sheet = workbook.addWorksheet(safeSheetName, { views: [{ state: 'frozen', ySplit: freezeRow }] });
        const headerRow = sheet.addRow(headers);
        headerRow.font = { bold: true, color: { argb: 'FFFFFFFF' }, size: 11 };
        headerRow.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF2A2A2A' } };
        headerRow.alignment = { vertical: 'middle', horizontal: 'center' };
        sheet.autoFilter = { from: { row: 1, column: 1 }, to: { row: 1, column: headers.length } };

        for (let i = 0; i < dataRows.length; i++) {
            const rowData = dataRows[i];
            const row = sheet.addRow(rowData);
            row.eachCell((cell, colNumber) => {
                const headerName = String(headers[colNumber - 1]).toLowerCase();
                const val = cell.value;
                
                if (val === null || val === undefined || val === "" || (typeof val === 'number' && !isFinite(val))) { 
                    cell.value = null; 
                } 
                else if (typeof val === 'string' && val.endsWith('%')) { 
                    const num = parseFloat(val) / 100; if (!isNaN(num)) { cell.value = num; cell.numFmt = '0.00%'; } 
                } 
                else if (typeof val === 'number') {
                    if (['acos', 'cvr', 'ctr', '转化率', '点击率'].some(k => headerName.includes(k))) { cell.numFmt = '0.00%'; } 
                    else if (['spend', 'sales', 'cpc', 'bid', 'profit', '花费', '销售额'].some(k => headerName.includes(k))) { cell.numFmt = '"$"#,##0.00'; } 
                    else if (!Number.isInteger(val) && !headerName.includes('roas')) { cell.numFmt = '0.00'; } 
                    else if (headerName.includes('roas')) { cell.numFmt = '0.00'; } 
                    else { cell.numFmt = '#,##0'; }
                }
                
                if ((headerName.includes('acos') || headerName === 'acos') && cell.value > 0.4) { cell.font = { color: { argb: 'FFB42318' }, bold: true }; cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFEE4E2' } }; }
                if ((headerName.includes('roas') || headerName === 'roas') && cell.value >= 3) { cell.font = { color: { argb: 'FF1A7F37' }, bold: true }; }
