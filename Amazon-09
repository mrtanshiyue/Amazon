const renderTrend = (rows) => {
  if (!rows || rows.length === 0) return; 
  const byDate = groupBy(rows, r=>r.date); 
  
  const bizMap = new Map();
  for (const r of BUSINESS_ROWS) {
    if (r.date) bizMap.set(r.date, (bizMap.get(r.date) || 0) + r.sales);
  }

  const series = [...byDate.keys()].sort().map(d => {
      const adMetrics = sumMetrics(byDate.get(d));
      // 如果没有真实业务数据，用广告销售额兜底，不再乘以 1.5 伪造数据
      let dailyBizSales = bizMap.has(d) ? bizMap.get(d) : adMetrics.sales; 
      const organicSales = Math.max(0, dailyBizSales - adMetrics.sales);
      const tacos = dailyBizSales > 0 ? (adMetrics.spend / dailyBizSales) * 100 : 0;
      return { date: d, ...adMetrics, organicSales, tacos };
  });

  const dataMap = (key, transform = v => v) => series.map(s => transform(s[key])); 
  const gridColor = getComputedStyle(document.documentElement).getPropertyValue('--chart-grid').trim() || "rgba(229,229,234,.6)"; 

  const datasets = [ 
    { type: "bar", label:"自然销售额 (真实)", data:dataMap("organicSales"), backgroundColor:"rgba(48, 209, 88, 0.4)", stack: 'Stack 0' },
    { type: "bar", label:"广告销售额", data:dataMap("sales"), backgroundColor:"rgba(10, 132, 255, 0.6)", stack: 'Stack 0' },
    { type: "line", label:"花费", data:dataMap("spend"), tension:.25, borderColor: "rgba(255, 69, 58, 1)", borderWidth:2, pointRadius: 0 }, 
    { type: "line", label:"TACoS %", data:dataMap("tacos"), tension:.25, borderDash: [5, 5], borderColor: "#ff9f0a", borderWidth:2, pointRadius: 0, yAxisID:"y1" }
  ];

  const canvas = $("trendChart");
  if (!canvas) return;

  if (trendChart) { 
      trendChart.data.labels = series.map(s=>s.date);
      trendChart.data.datasets = datasets;
      trendChart.options.scales.y.grid.color = gridColor;
      trendChart.update();
  } else {
      try { 
          trendChart = new Chart(canvas.getContext("2d"), { 
              data:{ labels:series.map(s=>s.date), datasets }, 
              options:{ 
                  responsive:true, maintainAspectRatio:false, interaction:{ mode:"index", intersect:false }, 
                  scales:{ 
                      y:{ stacked: true, grid:{ color: gridColor } }, 
                      y1:{ position:"right", grid:{ drawOnChartArea:false } }, 
                      x:{ stacked: true, grid:{ display:false } } 
                  } 
              } 
          }); 
      } catch(e) {} 
  }
};

const getRankKey = () => { const mapping = { searchTerm: r => r.searchTerm || "(空白)", searchTermRoot: r => r.searchTermRoot || "(空白)", targeting: r => r.targeting || "(空白)", campaign: r => r.campaign || "(空白)", adGroup: r => r.adGroup || "(空白)", }; return mapping[$("rankBy").value]; };

const sortRank = (items) => { 
    const {key, dir} = rankSort; const mul = dir==="asc" ? 1 : -1; 
    items.sort((a,b)=>{ 
        const av = key==="name"||key==="action"||key==="audit" ? String(a[key]||"") : (a[key] ?? 0); 
        const bv = key==="name"||key==="action"||key==="audit" ? String(b[key]||"") : (b[key] ?? 0); 
        if (typeof av === "string" && typeof bv === "string") return av.localeCompare(bv) * mul; 
        return (av === bv ? 0 : (av > bv ? 1 : -1)) * mul;
    }); 
};

const buildRankTable = () => { 
    const rankBy = $("rankBy").value; 
    const getMedian = (arr) => { if(!arr.length) return 0; arr.sort((a,b)=>a-b); return arr[Math.floor(arr.length/2)]; };
    const allCvrs = [], allCpcs = [], allCtrs = [], allRoas = [];
    
    for (const list of CURRENT_RANK_GROUPS.values()) {
        const m = sumMetrics(list);
        if (m.clicks >= 5) { allCvrs.push(m.smoothCvr); allCpcs.push(m.cpc); allCtrs.push(m.ctr); allRoas.push(m.roas); }
    }
    const medCtr = getMedian(allCtrs) || 0.008; const medCvr = getMedian(allCvrs) || 0.05; const medCpc = getMedian(allCpcs) || 1.0; const medRoas = getMedian(allRoas) || 2.0;
    const totalSales = VIEW.reduce((sum, r) => sum + r.sales, 0);
    const sortedForPareto = [...CURRENT_RANK_GROUPS.entries()].map(([name, list]) => ({name, sales: list.reduce((s, r)=>s+r.sales, 0)})).sort((a,b) => b.sales - a.sales);
    let cumSales = 0; const coreTerms = new Set();
    for (const item of sortedForPareto) { cumSales += item.sales; coreTerms.add(item.name); if (cumSales >= totalSales * 0.8) break; }

    let items = [...CURRENT_RANK_GROUPS.entries()].map(([name, list]) => { 
        const base = { name, ...sumMetrics(list) }; 
        const {action, reason, suggestedBidDelta} = decideAction(base, rankBy); 
        
        let audit = "-";
        if (coreTerms.has(name) && base.roas > 0 && base.roas < (medRoas * 0.5) && base.spend > 30) { audit = "核心失血"; } 
        else if (base.clicks >= 10 && base.ctr > medCtr && base.smoothCvr < (medCvr * 0.5)) { audit = "页面缺陷"; } 
        else if (base.cpc < medCpc && base.roas > (medRoas * 1.2) && base.smoothCvr > (medCvr * 1.1) && base.orders >= 1) { audit = "潜力词"; }

        if (audit === "-" && rankBy === "searchTerm" && !isASINLike(name)) {
            const termTokens = new Set(tokenize(name)); let isDrift = false;
            for (const r of list) {
                if (r.matchType && (r.matchType.toLowerCase().includes("broad") || r.matchType.toLowerCase().includes("phrase"))) {
                    if (!isASINLike(r.targeting)) {
                        const targetTokens = tokenize(r.targeting);
                        if (targetTokens.length > 0 && !targetTokens.some(t => termTokens.has(t))) { isDrift = true; break; }
                    }
                }
            }
            if (isDrift && base.clicks >= 5 && base.smoothCvr < medCvr) { audit = "匹配跑偏"; }
        }
        return { ...base, action, reason, suggestedBidDelta, audit }; 
    }); 
    if (rankTypeFilter !== "all") items = items.filter(it => detectRowType(it.name, rankBy) === rankTypeFilter); 
    sortRank(items); 
    RANK_ROWS = items.slice(0, clamp(safeNum($("rankTopN").value) || 30, 5, 500)); 
};

