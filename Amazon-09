const withinDate = (r, start, end) => (!start || r.date >= start) && (!end || r.date <= end);
const sumMetrics = (rows) => {
  let impr=0, clicks=0, spendCents=0, salesCents=0, orders=0;
  for (const r of rows) { impr += r.impr; clicks += r.clicks; orders += r.orders; spendCents += Math.round(r.spend * 100); salesCents += Math.max(0, Math.round(r.sales * 100)); }
  const spend = spendCents / 100; const sales = salesCents / 100;
  return { impr, clicks, spend, sales, orders, ctr: impr > 0 ? clicks / impr : 0, cpc: clicks > 0 ? spend / clicks : 0, cvr: clicks > 0 ? Math.min(1, orders / clicks) : 0, acos: sales > 0 ? spend / sales : 0, roas: spend > 0 ? Math.max(0, sales) / spend : 0 };
};
const groupBy = (rows, keyFn) => { const mp = new Map(); for (const r of rows) { const k = keyFn(r) || "(blank)"; (mp.has(k) ? mp : mp.set(k, [])).get(k).push(r); } return mp; };

const detectAnomalies = (rows) => {
    const container = $("anomalyAlerts"); if (!container) return; if (!rows || rows.length === 0) { container.style.display = "none"; container.innerHTML = ""; return; }
    const alerts = []; const groups = CURRENT_RANK_GROUPS || groupBy(rows, r => r.searchTerm); let topBleeder = null; let maxWasted = 0;
    for (const [term, list] of groups.entries()) { if (isASINLike(term)) continue; let spend = 0, orders = 0; for (const r of list) { spend += r.spend; orders += r.orders; } if (orders === 0 && spend > maxWasted) { maxWasted = spend; topBleeder = term; } }
    if (maxWasted > 30) { alerts.push({ type: 'bad', msg: `<strong>🚨 极端浪费预警：</strong> 核心词 <code>${escapeHtml(topBleeder)}</code> 在当前时间段内花费高达 <strong>$${maxWasted.toFixed(2)}</strong> 且 0 转化，建议立即排查相关性或加入否定！` }); }
    const dates = [...new Set(rows.map(r=>r.date).filter(Boolean))].sort();
    if (dates.length >= 4) {
        const recentDates = dates.slice(-2); const prevDates = dates.slice(-4, -2);
        const recentRows = rows.filter(r => recentDates.includes(r.date)); const prevRows = rows.filter(r => prevDates.includes(r.date));
        const mR = sumMetrics(recentRows); const mP = sumMetrics(prevRows);
        if (mP.clicks > 10 && mR.clicks > 10) {
            if (mR.spend > mP.spend * 2 && mR.spend > 20) { alerts.push({ type: 'warn', msg: `<strong>⚠️ 花费飙升预警：</strong> 近 2 天 (${recentDates.join(",")}) 广告花费 ($${mR.spend.toFixed(2)}) 相比前 2 天 ($${mP.spend.toFixed(2)}) 暴涨超过 100%，请警惕预算失控或恶意点击。` }); }
            if (mP.cvr > 0.05 && mR.cvr < mP.cvr * 0.5) { alerts.push({ type: 'warn', msg: `<strong>⚠️ 转化断崖预警：</strong> 近 2 天转化率 (${fmtPct(mR.cvr)}) 相比前 2 天 (${fmtPct(mP.cvr)}) 出现腰斩，请检查链接是否断货、被跟卖或收到差评。` }); }
        }
    }
    if (alerts.length > 0) { container.innerHTML = alerts.map(a => `<div class="alert-banner ${a.type === 'warn' ? 'warn' : ''}"> <span class="alert-icon">${a.type === 'warn' ? '⚠️' : '🚨'}</span> <div>${a.msg}</div> </div>`).join(""); container.style.display = "flex"; } else { container.style.display = "none"; container.innerHTML = ""; }
};

