const renderCPCDistribution = () => {
  const tbody = $("cpcDistTable")?.querySelector("tbody"); 
  if (!tbody) return; 
  if (!AdsStore.view.length) { tbody.innerHTML = ""; return; }
  
  const buckets = [{ label: "< 0.50", min:0, max:0.5, rows: [] }]; 
  for (let i = 5; i < 15; i++) { 
    const start = i / 10; const end = (i + 1) / 10; 
    buckets.push({ label: `${start.toFixed(2)} - ${end.toFixed(2)}`, min: start, max: end, rows: [] }); 
  } 
  buckets.push({ label: "> 1.50", min:1.5, max:9999, rows: [] });
  
  for (const r of AdsStore.view) { 
    if (r.clicks <= 0) continue; 
    const rowCpc = r.spend / r.clicks; 
    for(const b of buckets) { if (rowCpc >= b.min && rowCpc < b.max) { b.rows.push(r); break; } } 
  }
  const result = buckets.map(b => ({ ...b, metrics: sumMetrics(b.rows) })); 
  const totalMetrics = sumMetrics(AdsStore.view); 
  const totalSales = totalMetrics.sales || 1; 
  const totalOrders = totalMetrics.orders || 1; 
  
